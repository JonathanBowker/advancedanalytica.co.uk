---
const { hideContactCta = false } = Astro.props;
const leadEndpoint =
  "https://advancedanalytica-co-uk-omj3v.ondigitalocean.app/api/leads/contact";

const links = [
  { label: "About", href: "/company/about" },
  { label: "Security", href: "/company/security" },
  { label: "Contact", href: "/company/contact" },
  { label: "RSS Feeds", href: "/rss" },
  { label: "Privacy", href: "/legal/privacy" },
  { label: "Terms", href: "/legal/terms" },
];
---

{
  !hideContactCta && (
    <>
      <section class="bg-ink text-paper">
        <div class="container-wide py-20">
          <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
            <div>
              <div class="eyebrow text-paper/70">Next step</div>
              <h2
                class="mt-4 text-[clamp(2.2rem,4.6vw,3.75rem)] font-semibold tracking-tight text-paper"
              >
               Ready to see if your brand is AI-ready?
              </h2>
              <p
                class="mt-6 max-w-[80ch] text-lg leading-relaxed text-paper/80 md:text-xl"
              >
                Tell us where AI touches your brand and what needs to be governed. We will help you clarify the problem and define the right first move.
              </p>
            </div>

            <div class="flex flex-col gap-4">
              <a
                href="/brand-ai-readiness-assessment/#assessment-form"
                class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-8 py-4 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#0F766E] transition-colors"
              >
               Assess your brand's AI readiness
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 10h12" />
                  <path d="M12 6l4 4-4 4" />
                </svg>
              </a>
              <a
                href="/use-cases"
                class="inline-flex items-center justify-center rounded-md border border-paper/20 bg-transparent px-8 py-4 text-xs font-semibold tracking-[0.14em] uppercase text-paper hover:border-paper/40 transition-colors"
              >
                View use cases
              </a>
            </div>
          </div>
        </div>
      </section>

      <section
        id="get-in-touch"
        class="bg-[url('/images/get-in-touch/bgimage.webp')] bg-cover bg-center"
      >
        <div>
          <div class="container-wide py-24">
            <div class="grid overflow-hidden shadow-outline lg:grid-cols-[1fr_1fr]">
              <div class="relative min-h-[440px] overflow-hidden">
                <div class="absolute inset-0 bg-cover bg-center"></div>
                <div class="relative z-10 h-full">
                  <div class="absolute inset-x-0 bottom-0 bg-[#14B8A6]">
                    <div class="m-8 max-w-[360px] px-10 pb-6 text-ink">
                      <div class="text-8xl font-semibold tracking-tight">
                        Get in touch.
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div
                class="bg-paper p-12 lg:-mr-[calc(50vw-50%)] lg:pr-[calc(50vw-50%)]"
              >
                <form
                  id="home-contact-form"
                  action={leadEndpoint}
                  method="POST"
                  data-lead-form
                  data-lead-endpoint={leadEndpoint}
                  data-status-target="home-contact-status"
                  class="grid gap-6 max-w-[520px]"
                  novalidate
                >
                  <input
                    type="text"
                    name="website"
                    class="hidden"
                    tabindex="-1"
                    autocomplete="off"
                    aria-hidden="true"
                  />
                  <input type="hidden" name="language" value="en" />

                  <div class="grid gap-2">
                    <label for="home-name" class="text-base font-semibold text-ink/70"
                      >Name</label
                    >
                    <input
                      id="home-name"
                      name="name"
                      type="text"
                      autocomplete="name"
                      required
                      class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
                    />
                  </div>

                  <div class="grid gap-2">
                    <label
                      for="home-email"
                      class="text-base font-semibold text-ink/70">Email*</label
                    >
                    <input
                      id="home-email"
                      name="email"
                      type="email"
                      autocomplete="email"
                      inputmode="email"
                      required
                      class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
                    />
                    <p class="text-xs leading-relaxed text-steel">
                      This must be a business email address.
                    </p>
                  </div>

                  <div class="grid gap-2">
                    <label
                      for="home-subject"
                      class="text-base font-semibold text-ink/70">Subject*</label
                    >
                    <input
                      id="home-subject"
                      name="topic"
                      type="text"
                      required
                      class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
                    />
                  </div>

                  <div class="grid gap-2">
                    <label
                      for="home-message"
                      class="text-base font-semibold text-ink/70">Message</label
                    >
                    <textarea
                      id="home-message"
                      name="message"
                      rows="4"
                      required
                      class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
                    ></textarea>
                  </div>

                  <div class="pt-2">
                    <div class="flex justify-end pr-10">
                      <button
                        type="submit"
                        class="rounded-md bg-ink px-8 py-3 text-sm font-semibold text-paper"
                      >
                        Submit
                      </button>
                    </div>
                    <div
                      id="home-contact-status"
                      class="mt-3 text-sm text-steel"
                      aria-live="polite"
                    >
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </>
  )
}

<section class="relative overflow-hidden bg-slate text-paper">
  <div class="absolute inset-0 bg-slate" aria-hidden="true"></div>

  <div class="container-wide relative z-10 py-20">
    <div class="mx-auto max-w-[980px]">
      <img
        src="/images/infrastructure/logo.svg"
        alt="Advanced Analytica"
        loading="lazy"
        class="mx-auto h-10 w-auto opacity-100 md:h-12"
      />

      <div
        class="mt-10 grid gap-4 text-base leading-relaxed text-paper/85 md:text-lg"
      >
        <p>
          To succeed in a data-driven environment, organisations need more than
          traditional approaches. They need solutions that connect decision
          makers with the right information, expert judgement, and operational
          control when it matters most.
        </p>
        <p>
          Advanced Analytica works with organisations to protect and capitalise
          on AI and data, manage risk, improve transparency, control cost, and
          strengthen performance. Drawing on enterprise-level expertise and more
          than two decades of data management experience, we turn data, AI, and
          organisational knowledge into governed strategic assets.
        </p>
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-paper/10 bg-ink text-paper">
  <div class="container-wide flex flex-col gap-6 py-10 text-sm text-paper/70">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="text-xs font-semibold tracking-[0.2em] uppercase text-paper">
        Advanced Analytica
      </div>
      <div class="flex flex-wrap gap-4">
        {
          links.map((item) => (
            <a href={item.href} class="hover:text-paper transition-colors">
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="text-xs">© {new Date().getFullYear()} Advanced Analytica.</div>
  </div>
</footer>

<script src="/scripts/contact-leads.js" defer></script>
