---
import { getGeneratedCoverPath } from '../lib/contentCover';

const { resource } = Astro.props as {
  resource: {
    slug: string;
    data: {
      title: string;
      description: string;
      coverImage?: string;
      category?: string;
      tags?: string[];
    };
  };
};

const coverPath = getGeneratedCoverPath('resource', resource.slug);
const coverAlt = `${resource.data.title} — ${resource.data.description}`;
---
<article class="group rounded-xl border border-fog bg-surface p-6 shadow-outline">
  <a href={`/resources/${resource.slug}`} class="block overflow-hidden rounded-xl bg-[#0b0e14] shadow-outline">
    <img
      src={coverPath}
      alt={coverAlt}
      loading="lazy"
      class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
    />
  </a>

  <div class="mt-5 flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.2em] text-steel">
    <span>{resource.data.category ?? 'Resource'}</span>
  </div>

  <h3 class="mt-4 text-xl font-semibold text-ink">
    <a href={`/resources/${resource.slug}`} class="hover:text-accent transition-colors">
      {resource.data.title}
    </a>
  </h3>
  <p class="mt-3 text-sm text-steel">{resource.data.description}</p>
</article>
