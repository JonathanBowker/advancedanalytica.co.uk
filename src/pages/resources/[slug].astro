---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import components from '../../lib/mdx/components';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../lib/seo/site';
import { getGeneratedCoverPath } from '../../lib/contentCover';

export async function getStaticPaths() {
  const items = await getCollection('resources', ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props as { item: Awaited<ReturnType<typeof getCollection>>[number] };
const { Content } = await item.render();
const allItems = (await getCollection('resources', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
const related = allItems.filter((entry) => entry.slug !== item.slug).slice(0, 3);

const title = item.data.title;
const description = item.data.description;
const downloadUrl = item.data.downloadUrl;
const url = `${SITE_URL}/resources/${item.slug}`;
const coverImage = getGeneratedCoverPath('resource', item.slug);
const coverAlt = `${title} — ${description}`;

const page = {
  title,
  description,
  url,
  image: `${SITE_URL}${coverImage}`,
  imageAlt: coverAlt,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Resources', url: `${SITE_URL}/resources/` },
    { name: title, url }
  ]
};
---
<BaseLayout title={title} description={description} page={page} bodyClass="case-study">
  <section>
    <div class="relative z-10 bg-[#0b0e14]">
      <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
        <img
          src={coverImage}
          alt=""
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full scale-125 object-cover blur-2xl saturate-150 brightness-125 opacity-75"
        />
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/55"></div>
      </div>

      <div class="container-wide relative z-20 pt-10 pb-8">
        <a
          href="/resources"
          class="inline-flex items-center gap-3 text-sm font-semibold tracking-[0.2em] uppercase text-white/80 hover:text-white transition-colors"
        >
          <span class="text-2xl leading-none">←</span>
          BACK
        </a>

        <div class="mt-6 grid gap-10 lg:grid-cols-[480px_1fr] lg:items-start">
          <div class="lg:hidden">
            <img
              src={coverImage}
              alt={coverAlt}
              loading="eager"
              class="aspect-square w-full rounded-2xl object-cover shadow-outline"
            />
          </div>

          <div class="hidden lg:block" aria-hidden="true"></div>

          <div>
            {item.data.tags?.length ? (
              <div class="flex flex-wrap gap-3">
                {item.data.tags.map((tag) => (
                  <span class="rounded-sm bg-[#14B8A6] px-4 py-2 text-xs font-semibold uppercase text-paper">
                    {tag}
                  </span>
                ))}
              </div>
            ) : null}

            <h1 class="mt-4 text-[clamp(2rem,4vw,3.25rem)] font-normal tracking-tight text-white">
              {title}
            </h1>
            <div class="mt-6 text-sm text-white/70">{item.data.category ?? 'Resource'}</div>
            <div class="mt-6 flex flex-wrap items-center gap-4">
              {downloadUrl ? (
                <a
                  href={downloadUrl}
                  class="inline-flex items-center justify-center rounded-md bg-[#14B8A6] px-6 py-3 text-sm font-semibold tracking-[0.18em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
                >
                  Download PDF
                </a>
              ) : null}
              <ShareButtons url={url} title={title} description={description} variant="dark" />
            </div>
          </div>
        </div>

        <div class="pointer-events-none absolute left-0 bottom-0 z-30 hidden w-[480px] translate-y-1/2 lg:block">
          <img
            src={coverImage}
            alt={coverAlt}
            loading="eager"
            class="aspect-square w-full rounded-2xl object-cover shadow-outline"
          />
        </div>
      </div>
    </div>

    <div class="relative z-0 -mt-px bg-white">
      <div class="container-wide pb-6 pt-2 lg:pb-44">
        <div class="grid gap-10 lg:grid-cols-[480px_1fr]">
          <div></div>
          <div>
            <p class="max-w-[40ch] text-base leading-relaxed text-ink md:text-lg">
              {description}
            </p>
            <div class="mt-4">
              <a
                href="#resource-content"
                class="text-sm font-semibold tracking-[0.18em] uppercase text-orange-500 hover:text-orange-600"
              >
                READ MORE
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="resource-content" class="bg-white pt-px">
    <div class="container-wide pb-16">
      <div class="max-w-[900px]">
        <article class="prose prose-case-study">
          <Content components={components} />
        </article>
      </div>
    </div>
  </section>

  <section class="container-wide pt-8 pb-20">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-2xl font-semibold text-ink">Related Resources</h2>
      <a href="/resources" class="text-xs font-semibold tracking-[0.2em] uppercase text-steel hover:text-ink">
        View All
      </a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {related.map((entry) => (
        <a href={`/resources/${entry.slug}`} class="rounded-xl border border-fog bg-surface p-6">
          <div class="text-xs uppercase tracking-[0.2em] text-steel">{entry.data.category ?? 'Resource'}</div>
          <div class="mt-3 text-lg font-semibold text-ink">{entry.data.title}</div>
          <p class="mt-2 text-sm text-steel">{entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
