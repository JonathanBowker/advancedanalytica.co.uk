---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../../lib/seo/site";
import { businessFunctions } from "../../lib/businessFunctions";

const personas = (await getCollection("personas", ({ data }) => !data.draft)).sort((a, b) => {
  if (a.data.functionSlug !== b.data.functionSlug) {
    return a.data.functionSlug.localeCompare(b.data.functionSlug);
  }

  return a.data.roleTitle.localeCompare(b.data.roleTitle);
});

const title = "Synthetic Personas";
const description =
  "Internal preview pages for synthetic role personas used to answer questions and generate more role-specific content.";

const page = {
  title,
  description,
  url: `${SITE_URL}/personas/`,
  breadcrumbs: [
    { name: "Home", url: `${SITE_URL}/` },
    { name: title, url: `${SITE_URL}/personas/` },
  ],
};
---

<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16 md:py-20">
    <div class="eyebrow">Internal Preview</div>
    <h1 class="mt-4 text-[clamp(2.4rem,4.6vw,4rem)] font-semibold tracking-tight text-ink">
      Synthetic personas
    </h1>
    <p class="mt-5 max-w-[72ch] text-lg leading-relaxed text-steel md:text-xl">
      These editable `.mdx` persona files sit behind the role pages and help us answer questions, shape messaging,
      and generate more useful content for real people in each function.
    </p>

    <div class="mt-12 space-y-12">
      {
        businessFunctions.map((entry) => {
          const items = personas.filter((persona) => persona.data.functionSlug === entry.slug);
          if (!items.length) return null;

          return (
            <section>
              <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ef27f4]">
                {entry.eyebrow}
              </div>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink">{entry.title}</h2>
              <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                {items.map((persona) => (
                  <a
                    href={`/personas/${persona.slug}/`}
                    class="rounded-2xl border border-fog bg-surface p-8 shadow-outline transition-colors hover:border-[#ef27f4]"
                  >
                    <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[#ef27f4]">
                      {persona.data.seniority}
                    </div>
                    <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink">
                      {persona.data.personaName}
                    </h3>
                    <p class="mt-2 text-base font-medium text-ink">{persona.data.roleTitle}</p>
                    <p class="mt-4 text-base leading-relaxed text-steel">{persona.data.summary}</p>
                  </a>
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
