---
import BaseLayout from "../../layouts/BaseLayout.astro";
import components from "../../lib/mdx/components";
import { getCollection } from "astro:content";
import { SITE_URL } from "../../lib/seo/site";
import { businessFunctions, getRolePath } from "../../lib/businessFunctions";

export async function getStaticPaths() {
  const personas = await getCollection("personas", ({ data }) => !data.draft);
  return personas.map((persona) => ({
    params: { slug: persona.slug },
    props: { persona },
  }));
}

const { persona } = Astro.props as {
  persona: Awaited<ReturnType<typeof getCollection<"personas">>>[number];
};

const { Content } = await persona.render();
const entry = businessFunctions.find((item) => item.slug === persona.data.functionSlug);

const title = persona.data.title;
const description = persona.data.summary;
const url = `${SITE_URL}/personas/${persona.slug}/`;

const page = {
  title,
  description,
  url,
  breadcrumbs: [
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Synthetic Personas", url: `${SITE_URL}/personas/` },
    { name: title, url },
  ],
};
---

<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <a href="/personas/" class="text-xs font-semibold tracking-[0.2em] uppercase text-steel hover:text-ink">
      ← Back to personas
    </a>
    <div class="mt-8 text-xs font-semibold tracking-[0.2em] uppercase text-[#ef27f4]">
      {entry?.eyebrow ?? persona.data.functionSlug}
    </div>
    <h1 class="mt-4 text-[clamp(2.2rem,4vw,3.6rem)] font-semibold tracking-tight text-ink">
      {persona.data.personaName}
    </h1>
    <p class="mt-3 text-lg font-medium text-ink">{persona.data.roleTitle}</p>
    <p class="mt-2 text-sm font-semibold uppercase tracking-[0.16em] text-steel">
      {persona.data.seniority}
    </p>
    <p class="mt-6 max-w-[70ch] text-lg leading-relaxed text-steel">
      {persona.data.organisationContext}
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      {entry ? (
        <a
          href={getRolePath(entry.slug, persona.data.roleTitle)}
          class="inline-flex items-center justify-center gap-2 rounded-md bg-[#ef27f4] px-5 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper transition-colors hover:bg-[#d823dd]"
        >
          View role page
        </a>
      ) : null}
      {entry ? (
        <a
          href={`/functions/${entry.slug}/`}
          class="inline-flex items-center justify-center gap-2 rounded-md border border-[#ef27f4] px-5 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-[#ef27f4] transition-colors hover:bg-[#ef27f4] hover:text-paper"
        >
          View function page
        </a>
      ) : null}
    </div>
  </section>

  <section class="container-wide pb-20">
    <article class="prose">
      <Content components={components} />
    </article>
  </section>
</BaseLayout>
