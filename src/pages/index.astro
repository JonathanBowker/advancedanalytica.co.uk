    <script is:inline define:vars={{ defaultUsesKey }}>
      (() => {
        const tablist = document.getElementById("uses-tabs");
        if (!tablist) return;

        const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
        const panels = new Map(
          Array.from(document.querySelectorAll("[data-panel]")).map((el) => [
            el.getAttribute("data-panel"),
            el,
          ]),
        );
        const visuals = new Map(
          Array.from(document.querySelectorAll("[data-visual]")).map((el) => [
            el.getAttribute("data-visual"),
            el,
          ]),
        );

        const activate = (key, focus = false) => {
          tabs.forEach((t) => {
            const selected = t.getAttribute("data-tab") === key;
            t.setAttribute("aria-selected", selected ? "true" : "false");
            t.tabIndex = selected ? 0 : -1;
          });
          panels.forEach((panel, panelKey) => {
            panel.hidden = panelKey !== key;
          });
          visuals.forEach((visual, visualKey) => {
            visual.hidden = visualKey !== key;
          });
          if (focus)
            tabs.find((t) => t.getAttribute("data-tab") === key)?.focus();
        };

        const selected =
          tabs.find((t) => t.getAttribute("aria-selected") === "true") ||
          tabs[0];
        activate(selected?.getAttribute("data-tab") || defaultUsesKey);

        tabs.forEach((t) => {
          t.addEventListener("click", () =>
            activate(t.getAttribute("data-tab"), true),
          );
          t.addEventListener("keydown", (e) => {
            if (
              e.key !== "ArrowLeft" &&
              e.key !== "ArrowRight" &&
              e.key !== "Home" &&
              e.key !== "End"
            )
              return;
            e.preventDefault();
            const currentIndex = tabs.indexOf(t);
            const nextIndex =
              e.key === "Home"
                ? 0
                : e.key === "End"
                  ? tabs.length - 1
                  : e.key === "ArrowRight"
                    ? (currentIndex + 1) % tabs.length
                    : (currentIndex - 1 + tabs.length) % tabs.length;
            const next = tabs[nextIndex];
            activate(next.getAttribute("data-tab"), true);
          });
        });
      })();
    </script>
