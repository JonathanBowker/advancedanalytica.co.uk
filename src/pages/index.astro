---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AiceGatewayCluster from "../components/AiceGatewayCluster.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../lib/seo/site";
import { businessFunctions } from "../lib/businessFunctions";
import usesPurposeUnderstandingImg from "../components/uses/assessment.svg?url";
import usesSystemFramingImg from "../components/uses/frame.svg?url";
import usesSpecificationDesignImg from "../components/uses/codification.svg?url";
import usesValidationEvaluationImg from "../components/uses/evaluation.svg?url";
import usesExecutionGenerationImg from "../components/uses/operation.svg?url";
import usesDeploymentOperationalUseImg from "../components/uses/optimisation.svg?url";
import usesRevisionGovernanceImg from "../components/uses/definition.svg?url";

const title = "Intelligent Business Operating Model (IBOM)";
const description =
  "Advanced Analytica helps organisations turn business logic into governed, executable infrastructure for AI systems, starting with brand governance.";
const usesTabs = [
  {
    key: "purpose_understanding",
    label: "1. Purpose",
    stage: "Stage 1",
    phase: "Phase 1",
    heading: "BUSINESS PURPOSE",
    subheading: "Define business purpose, outcomes, and constraints.",
    body: "Set the business purpose, strategic outcomes, success measures, and operating boundaries for the system. This phase makes sure the work is anchored to real organisational need from the start. By the end of it, everyone is clear on what the system is for, how success will be judged, and what constraints must always be respected.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesPurposeUnderstandingImg,
  },
  {
    key: "system_framing",
    label: "2. Mapping",
    stage: "Stage 2",
    phase: "Phase 1",
    heading: "KNOWLEDGE MAPPING",
    subheading: "Define the knowledge, sources, actors, and operating context.",
    body: "Identify the business knowledge, source materials, rules, expertise, tools, and integrations that will shape the system. This phase establishes the trusted context the model will depend on. By the end of it, the relevant sources, actors, and operating environment are clear enough to move into structured specification.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesSystemFramingImg,
  },
  {
    key: "specification_design",
    label: "3. Specify",
    stage: "Stage 3",
    phase: "Phase 1",
    heading: "KNOWLEDGE SPECIFICATION",
    subheading: "Turn business logic into machine-operable specifications.",
    body: "Translate business rules, expert judgement, processes, and policies into structured specifications that systems can interpret and act on. At the heart of this is a domain definition language that uses dot syntax and snake_case to express business concepts, policies, controls, and instructions in a consistent machine-readable form. By the end of this phase, you have a specification layer that can drive build, assurance, and live operation.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesSpecificationDesignImg,
  },
  {
    key: "execution_generation",
    label: "4. Build",
    stage: "Stage 4",
    phase: "Phase 2",
    heading: "SYSTEM BUILD",
    subheading: "Design and build governed AI systems from specification.",
    body: "Use the approved specifications to supervise the design and implementation of working systems. This phase turns the knowledge base into applications, agents, workflows, and tools that operate within clear governance boundaries. By the end of it, the system is built and ready to move through structured assurance.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesExecutionGenerationImg,
  },
  {
    key: "validation_evaluation",
    label: "5. Evaluate",
    stage: "Stage 5",
    phase: "Phase 2",
    heading: "ASSURANCE & EVALUATION",
    subheading: "Test safety, accuracy, performance, and policy adherence.",
    body: "Validate that the system performs as intended against business objectives, operational rules, and governance requirements. This includes testing for quality, safety, edge cases, compliance, and fidelity to specification before release. By the end of this phase, there is evidence that the system is ready for live use within agreed thresholds.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesValidationEvaluationImg,
  },
  {
    key: "deployment_operational_use",
    label: "6. Deploy",
    stage: "Stage 6",
    phase: "Phase 2",
    heading: "AICE DEPLOYMENT & OPERATION",
    subheading:
      "Deploy the AICE with control, monitoring, and live governance.",
    body: "Deploy the system into production through the AICE with clear controls, monitoring, and operational oversight. This phase ensures the system can be used confidently in live environments while maintaining transparency, traceability, and performance at scale. By the end of it, the system is running through governed infrastructure with the visibility needed for trustworthy ongoing use.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesDeploymentOperationalUseImg,
  },
  {
    key: "revision_governance",
    label: "7. Govern",
    stage: "Stage 7",
    phase: "Phase 2",
    heading: "REVISION & GOVERNANCE",
    subheading: "Continuously refine the system as needs evolve.",
    body: "Maintain the system through structured review, revision, and governance. As needs, risks, models, and environments change, specifications and implementations are updated in a controlled way so the operating model stays aligned and trustworthy. By the end of this phase, improvement is continuous and governance is part of how the system evolves over time.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesRevisionGovernanceImg,
  },
] as const;
const postFilterChips = [
  "All",
  "Governance",
  "Knowledge",
  "Systems",
  "Operation",
  "MCP",
] as const;
const defaultUsesKey = usesTabs[0].key;
const latestPosts = (
  await getCollection("blog", ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const HOME_POST_INITIAL_COUNT = 3;
const HOME_POST_BATCH_SIZE = 3;
const page = {
  title,
  description,
  url: `${SITE_URL}/`,
  breadcrumbs: [{ name: "Home", url: `${SITE_URL}/` }],
};
---

<BaseLayout title={title} description={description} page={page}>
  <!-- 1. HERO -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper min-h-[calc(100vh-5rem)]"
  >
    <div
      class="container-wide relative z-10 pt-[9.5rem] pb-[8.5rem] lg:pt-[10.5rem] lg:pb-[9.5rem]"
    >
      <div class="grid gap-12 lg:items-center">
        <div>
          <div class="eyebrow mb-12 text-base">
            Expert-Led. Spec-Driven. AI-Scaled.
          </div>

          <h1
            class="font-masthead text-[clamp(2.95rem,5.6vw,5.15rem)] font-semibold tracking-tight text-paper leading-[1.06] max-w-[52rem] md:max-w-[56rem]"
          >
            <span class="block">Stop Trusting AI.</span>
            <span class="block text-[#14B8A6]">Start Governing It.</span>
          </h1>
          <h2
            class="mt-6 max-w-[46rem] text-[clamp(1.3rem,2.3vw,2rem)] font-light leading-snug text-paper/100"
          >
            Ungoverned AI is not an assistant. It is a liability.
          </h2>

          <p
            class="mt-5 max-w-[46rem] text-[clamp(1.16rem,1.85vw,1.42rem)] font-light leading-relaxed text-paper/80 md:text-[1.36rem]"
          >
           Advanced Analytica provides the rare data skills, bespoke toolkits and domain expertise
            needed to turn your organisation’s knowledge, policies, and expert judgement
            into
            <strong class="font-medium text-paper"
              >machine-operable specifications</strong
            > that make AI systems
            <strong class="font-medium text-paper"
              >consistent, trustworthy, and scalable.</strong
            >
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#get-in-touch"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-6 py-3 text-xs font-semibold leading-none tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
            >
              Get in touch
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12"></path>
                <path d="M12 6l4 4-4 4"></path>
              </svg>
            </a>
            <a
              href="#why"
              class="inline-flex items-center justify-center gap-3 rounded-md border border-[#ff8c69] px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-[#ff8c69] transition-colors hover:bg-[#ff8c69] hover:text-paper"
            >
              <span>Keep Reading</span>
              <svg
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Diagnosis -->
  <section id="why" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-10 text-center">Why It Matters</div>
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <h2
            class="text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
          >
            From Dark Knowledge to Governed AI Infrastructure
          </h2>
        </div>

        <div class="max-w-prose text-lg leading-relaxed text-steel md:text-xl">
          <p>
            Ungoverned AI is not a productivity tool. It is an operational
            liability. The problem isn’t the AI, it’s the data. Business logic,
            brand guidelines, and compliance procedures exist as Dark Knowledge:
            buried in static PDFs, siloed SaaS tools, spreadsheets, and the
            heads of your best people.
          </p>
          <p class="mt-6">
            The <b>IBOM<sup>®</sup></b> bridges this gap as a <b
              >brand-first operating model</b
            >, engineering institutional wisdom into a governed logic layer. We
            transform unwritten rules into machine-readable law, scaling from
            brand governance to complex enterprise operations. By establishing a
            practical, enforceable standard for every workflow, we move you
            beyond the unsure. <b>We train your AI to govern your AI.</b>
          </p>
        </div>
      </div>
      <div class="mt-12 flex items-center justify-center">
        <a
          href="#concerns"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#e97d5d] transition-colors"
          aria-label="Explore the next section"
        >
          <span>Keep Reading</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 3. How we work -->

  <section id="concerns" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center opacity-70">The Methodology</div>
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper"
      >
        Governance Engineering: The Lifecycle
      </h2>
      <p
        class="mx-auto mt-10 max-w-[90ch] text-lg leading-relaxed text-paper/80 md:text-xl text-center"
      >
        Our approach is a rigorous, three-stage pipeline designed to scale human
        judgment without compromising control. We move your expertise from the <span
          class="text-paper font-medium">"Dark Knowledge"</span
        > space into a <span class="text-paper font-medium"
          >Governed Intelligence Layer</span
        >.
      </p>

      <div class="mt-14 grid gap-4 lg:grid-cols-3">
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Knowledge Discovery
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We systematically extract business logic, workflow nuances, and
            "Dark Knowledge" to ensure the resulting system is architected
            around the actual operational DNA of your organisation.
          </p>
        </div>
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Spec Engineering
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We codify requirements into machine language using a domain
            definition language with dot syntax and snake_case, creating
            expert-validated specifications and policies that AI agents can
            interpret consistently and follow in practice.
          </p>
        </div>
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Intelligence Activation
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We transition specifications into a production environment,
            supervising the automated building, testing, remediation and
            deployment of your intelligence at the speed of thought.
          </p>
        </div>
      </div>

      <div class="mt-16 border-t border-paper/20 pt-16">
        <h3
          class="text-center text-3xl font-semibold tracking-tight text-paper md:text-4xl"
        >
          Knowledge Building & Intelligence Activation
        </h3>
        <p
          class="mx-auto mt-6 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl"
        >
          We deliver IBOM<sup>®</sup> in two connected phases. The first builds the
          knowledge base. The second activates that knowledge through the AICE. Both
          phases are structured by the same seven-stage operating model.
        </p>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2">
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]"
          >
            Phase 1
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Knowledge Base Build
          </div>
          <p class="mt-4 text-paper/80">
            We transform institutional wisdom into structured, machine-language
            datasets that your organisation owns outright. <b
              >No vendor lock-in</b
            >, just portable, governed intelligence.
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Codify</b> specialist knowledge into high-fidelity structured
                records.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Construct</b> governed datasets and policy structures expressed
                in a machine-readable domain language.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Deliver</b> a retrieval-ready knowledge base optimised for secure
                exchange.</span
              >
            </li>
          </ul>
        </div>

        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]"
          >
            Phase 2
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Knowledge Base Gateway
          </div>
          <p class="mt-4 text-paper/80">
            We build the retrieval layer that makes your knowledge a live,
            queryable service. <b
              >Your expertise becomes accessible through the AI Communications
              Engine (AICE).</b
            >
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Design</b> retrieval systems for real-time accuracy at an enterprise
                scale.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Deploy</b> the AICE as a governed interface for universal AI tool
                connection.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Activate</b> live workflows with automated oversight and deterministic
                controls.</span
              >
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#engine"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper hover:bg-[#e97d5d] transition-colors"
        >
          <span>The Infrastructure</span>
          <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. The Infrastructure -->
  <section id="engine" class="bg-paper py-20 text-ink">
    <div class="container-wide">
      <div class="eyebrow mb-6 text-center">The Infrastructure</div>

      <div class="mx-auto max-w-5xl">
        <h2
          class="text-[clamp(2.2rem,4vw,3.5rem)] font-semibold tracking-tight leading-[1.1] text-center"
        >
          The AICE: Your Intelligence Control Centre
        </h2>
        <div
          class="mt-6 text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6] text-center"
        >
          What it is
        </div>
        <p
          class="mx-auto mt-3 max-w-4xl text-xl text-steel font-light leading-relaxed text-center"
        >
          If the IBOM<sup>®</sup> is the blueprint for your business, the <b
            >AI Communications Engine (AICE)</b
          > is the engine that drives it. It is a secure, governed gateway that sits
          between your people, your data, and your AI systems. It acts as a permanent
          translator and governor for every AI interaction, turning business intent
          into controlled machine action.
        </p>

        <div
          class="mt-8 text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6] text-center"
        >
          What it does
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Translates Intent into Action
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              The AICE turns a simple request into precise instructions shaped
              by your business logic, so AI follows engineered rules instead of
              guessing.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Acts as a Protective Shield
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              It stands between AI and your internal systems, controlling what
              data can be seen, what actions can be taken, and what must always
              remain off limits.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Coordinates Your Tools
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              It connects AI to the systems your business already relies on,
              from documents and databases to operational software, through one
              governed point of control.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Enforces the Standard
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              If an output is off-brand, incorrect, or policy-breaking, the AICE
              catches it before it reaches the user, turning AI from uncertain
              to reliable.
            </p>
          </div>
        </div>

        <div
          id="ibom-visual"
          class="relative mt-10 w-full scroll-mt-28"
          aria-label="IBOM Intelligent Business Operating Model visualisation"
        >
          <AiceGatewayCluster />
        </div>

        <div
          class="mt-10 rounded-2xl border border-[#14B8A6]/20 bg-[#14B8A6]/5 p-6"
        >
          <div
            class="text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6]"
          >
            The Bottom Line
          </div>
          <p class="mt-3 text-lg leading-relaxed text-ink">
            Without the AICE, you are interacting with a chatbot. With the AICE,
            you are operating a brand-first enterprise-grade intelligence
            system.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. IBOM Framework (tabs) -->
  <section id="uses" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center">Framework</div>
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
      >
        IBOM<sup class="text-[0.45em] align-super">®</sup> Framework
      </h2>
      <p
        class="mx-auto mt-6 max-w-4xl text-center text-lg font-light leading-relaxed text-steel md:text-xl"
      >
        IBOM<sup class="text-[0.45em] align-super">®</sup> is a brand-first operating
        model. This seven-stage framework structures both delivery phases: from defining
        purpose and mapping knowledge through to specification, evaluation, deployment,
        and governance.
      </p>

      <div class="mt-10">
        <div
          id="uses-tabs"
          role="tablist"
          aria-label="Advanced Analytica IBOM Uses"
          class="flex w-full flex-wrap items-center justify-between gap-1 rounded-md bg-fog p-2"
        >
          {
            usesTabs.map((t) => (
              <button
                type="button"
                role="tab"
                aria-selected={t.key === defaultUsesKey ? "true" : "false"}
                aria-controls={`uses-panel-${t.key}`}
                id={`uses-tab-${t.key}`}
                data-tab={t.key}
                class="flex-1 rounded-md px-5 py-3 text-base font-medium text-ink/80 transition-colors hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-[#14B8A6]/70 aria-selected:bg-[#14B8A6] aria-selected:text-paper aria-selected:shadow-sm"
              >
                {t.label}
              </button>
            ))
          }
        </div>
      </div>

      <div
        class="mt-14 grid gap-12 lg:gap-24 lg:grid-cols-[420px_1fr] lg:items-start"
      >
        <div
          class="relative overflow-hidden rounded-2xl bg-slate shadow-outline"
        >
          <div class="aspect-square">
            {
              usesTabs.map((t) => (
                <img
                  src={t.image}
                  alt=""
                  aria-hidden="true"
                  data-visual={t.key}
                  hidden={t.key === defaultUsesKey ? undefined : true}
                  class="h-full w-full object-cover"
                  decoding="async"
                  loading="lazy"
                />
              ))
            }
          </div>
        </div>

        <div class="max-w-prose pt-2">
          {
            usesTabs.map((t) => (
              <div
                role="tabpanel"
                id={`uses-panel-${t.key}`}
                aria-labelledby={`uses-tab-${t.key}`}
                data-panel={t.key}
                hidden={t.key === defaultUsesKey ? undefined : true}
