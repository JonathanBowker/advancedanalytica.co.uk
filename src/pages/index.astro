---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AiceGatewayCluster from "../components/AiceGatewayCluster.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../lib/seo/site";
import { businessFunctions } from "../lib/businessFunctions";
import usesPurposeUnderstandingImg from "../components/uses/assessment.svg?url";
import usesSystemFramingImg from "../components/uses/frame.svg?url";
import usesSpecificationDesignImg from "../components/uses/codification.svg?url";
import usesValidationEvaluationImg from "../components/uses/evaluation.svg?url";
import usesExecutionGenerationImg from "../components/uses/operation.svg?url";

const title = "Intelligent Business Operating Model (iBOM)";
const description =
  "We help businesses turn brand standards, business logic, and expert judgement into governed AI controls.";

const usesTabs = [
  {
    key: "purpose_understanding",
    label: "1. Discover",
    stage: "Stage 1",
    phase: "Phase 1",
    heading: "DISCOVER",
    subheading: "Understand the brand problem before you build anything.",
    body: "We map your brand standards, business context, priority AI use cases, and the knowledge already present across your teams, documents, systems, and workflows. This shows what is clear, where ambiguity lives, and what your AI needs to account for before a single specification is written.",
    href: "#brand-ai-readiness",
    cta: "Assess readiness",
    image: usesPurposeUnderstandingImg,
  },
  {
    key: "system_framing",
    label: "2. Specify",
    stage: "Stage 2",
    phase: "Phase 1",
    heading: "SPECIFY",
    subheading: "Define what AI must know, do, and never do.",
    body: "We turn your rules, constraints, approvals, tone standards, and escalation paths into explicit specifications. Not a loose requirements document. A machine-readable governing contract your AI systems can follow.",
    href: "#brand-ai-readiness",
    cta: "Assess readiness",
    image: usesSystemFramingImg,
  },
  {
    key: "specification_design",
    label: "3. Validate",
    stage: "Stage 3",
    phase: "Phase 1",
    heading: "VALIDATE",
    subheading: "Test ambiguity before AI acts on your behalf.",
    body: "We challenge the specification against the roles, intents, and scenarios your AI will meet. This shows where the rules hold, where they conflict, and where stronger controls are needed before build starts.",
    href: "#role-intent",
    cta: "See testing method",
    image: usesSpecificationDesignImg,
  },
  {
    key: "execution_generation",
    label: "4. Develop",
    stage: "Stage 4",
    phase: "Phase 2",
    heading: "DEVELOP",
    subheading: "Build from the approved specification.",
    body: "We build the governed system from the specification under expert oversight. Every workflow, agent behaviour, control, and escalation path traces back to the rules your business approved.",
    href: "#engine",
    cta: "See control layer",
    image: usesExecutionGenerationImg,
  },
  {
    key: "validation_evaluation",
    label: "5. Operate",
    stage: "Stage 5",
    phase: "Phase 2",
    heading: "OPERATE",
    subheading: "Run with governance. Extend without losing control.",
    body: "We help you operate the deployed system with monitoring, behavioural controls, review paths, and structured extension. Your AI can grow without drifting away from the standards your brand depends on.",
    href: "#get-in-touch",
    cta: "Request assessment",
    image: usesValidationEvaluationImg,
  },
] as const;

const postFilterChips = [
  "All",
  "Governance",
  "Knowledge",
  "Systems",
  "Operation",
  "MCP",
] as const;

const defaultUsesKey = usesTabs[0].key;
const latestPosts = (
  await getCollection("blog", ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const HOME_POST_INITIAL_COUNT = 3;
const HOME_POST_BATCH_SIZE = 3;
const page = {
  title,
  description,
  url: `${SITE_URL}/`,
  breadcrumbs: [{ name: "Home", url: `${SITE_URL}/` }],
};
---

<BaseLayout title={title} description={description} page={page}>
  <!-- 1. HERO -->
  <section
    class="relative min-h-[calc(100vh-5rem)] overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper"
  >
    <div
      class="container-wide relative z-10 pt-[9.5rem] pb-[8.5rem] lg:pt-[10.5rem] lg:pb-[9.5rem]"
    >
      <div class="grid gap-12 lg:grid-cols-[1fr_0.45fr] lg:items-center">
        <div>
          <div class="eyebrow mb-10 text-left">
            BRAND-FIRST. EXPERT-LED. AI-ENABLED.
          </div>

          <h1
            class="font-masthead max-w-[52rem] text-[clamp(2.95rem,5.6vw,5.15rem)] font-semibold leading-[1.06] tracking-tight text-paper md:max-w-[56rem]"
          >
            <span class="block">
              The <span class="text-[#14B8A6]">brand-first</span>
            </span>
            <span class="block">operating model</span>
            <span class="block">for governed AI</span>
          </h1>

          <h2
            class="mt-6 max-w-[46rem] text-[clamp(1.3rem,2.3vw,2rem)] font-light leading-snug text-paper/100"
          >
            Your brand guidelines were not built for AI agents.
          </h2>

          <p
            class="mt-5 max-w-[46rem] text-[clamp(1.16rem,1.85vw,1.42rem)] font-light leading-relaxed text-paper/80 md:text-[1.36rem]"
          >
            iBOM<sup>&reg;</sup> turns brand standards, business logic, and expert judgement
            into machine-operable controls. We test those controls against real roles
            and intents before AI acts on your behalf. You get governed workflows,
            traceable decisions, and a clear control layer across your brand, people,
            knowledge, and AI systems.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/brand-ai-readiness-assessment/#assessment-form"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-6 py-3 text-xs font-semibold leading-none tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
            >
              Assess your brand's AI readiness
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12"></path>
                <path d="M12 6l4 4-4 4"></path>
              </svg>
            </a>

            <a
              href="#why"
              class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#e97d5d]"
            >
              <span>Explore iBOM</span>
              <svg
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-paper/10 bg-paper/5 p-8 backdrop-blur">
          <div
            class="text-[clamp(3.5rem,8vw,6rem)] font-semibold leading-none tracking-tight text-[#14B8A6]"
          >
            74%
          </div>
          <p class="mt-4 text-lg font-light leading-snug text-paper/80">
            of businesses plan to deploy AI agents within two years.
          </p>

          <div class="mt-6 border-t border-paper/15 pt-6">
            <div
              class="text-[clamp(3.5rem,8vw,6rem)] font-semibold leading-none tracking-tight text-[#ff8c69]"
            >
              21%
            </div>
            <p class="mt-4 text-lg font-light leading-snug text-paper/80">
              have a mature governance model in place to control them.
            </p>
          </div>

          <p class="mt-6 text-xs leading-relaxed text-paper/40">
            Source: Deloitte State of AI in the Enterprise, January 2026
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. WHY IT MATTERS -->
  <section id="why" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-10 text-center">Why It Matters</div>

      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <h2
            class="text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
          >
            Your brand exists. AI can't operate it yet.
          </h2>
        </div>

        <div class="max-w-prose text-lg leading-relaxed text-steel md:text-xl">
          <p>
            Most businesses already have the raw material: brand standards,
            toolkits, policies, approvals, content rules, and expert judgement.
          </p>

          <p class="mt-6">
            The problem is format. That knowledge was built for people. AI
            agents need rules they can interpret, test, and apply without
            guessing.
          </p>

          <p class="mt-6">
            iBOM<sup>&reg;</sup> changes that. It turns your brand standards,
            business logic, and expert judgement into machine-operable controls
            your AI can follow.
          </p>

          <p class="mt-6">
            We test those controls against the roles and intents your AI will
            meet. You see what is ready, what creates ambiguity, and what needs
            stronger governance first.
          </p>
        </div>
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#brand-ai-readiness"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#e97d5d]"
          aria-label="Assess your brand's AI readiness"
        >
          <span>Assess readiness</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 3. DIAGNOSTIC OFFER -->
  <section id="brand-ai-readiness" class="bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper">
    <div class="container-wide py-20">
      <div class="grid gap-12 lg:grid-cols-[7fr_5fr] lg:items-center">
        <div>
          <div class="eyebrow mb-6 text-[#14B8A6]">Diagnostic Offer</div>
          <h2
            class="max-w-[12ch] text-[clamp(2.7rem,5vw,5rem)] font-semibold leading-[1.02] tracking-tight text-paper"
          >
            Assess your brand's AI readiness.
          </h2>
          <p class="mt-8 max-w-[62ch] text-lg leading-relaxed text-paper/75 md:text-xl">
            Before AI acts on your behalf, you need to know whether your brand
            rules are clear enough to govern it.
          </p>
          <p class="mt-6 max-w-[62ch] text-lg leading-relaxed text-paper/75 md:text-xl">
            Our Brand AI Readiness Assessment reviews your standards, toolkits,
            approval rules, and priority AI use cases. You see where AI can
            follow your brand, where ambiguity appears, and where stronger
            controls are needed first.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/brand-ai-readiness-assessment/"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-6 py-3 text-xs font-semibold leading-none tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
            >
              Request assessment
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12"></path>
                <path d="M12 6l4 4-4 4"></path>
              </svg>
            </a>
            <a
              href="#role-intent"
              class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#e97d5d]"
            >
              What we test
              <svg class="h-6 w-6 text-paper" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-paper/10 bg-paper/5 p-8 shadow-outline backdrop-blur">
          <div class="text-sm font-semibold tracking-[0.2em] uppercase text-[#ff8c69]">
            You get
          </div>
          <ul class="mt-8 space-y-6 text-paper/80">
            <li class="flex gap-4">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span>A structured review of your brand standards, toolkits, policies, and AI use cases.</span>
            </li>
            <li class="flex gap-4">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span>A readiness score across machine-readability, ambiguity, and AI control.</span>
            </li>
            <li class="flex gap-4">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span>A risk map showing where AI may misread, over-interpret, or ignore your brand rules.</span>
            </li>
            <li class="flex gap-4">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span>A practical action plan with Critical, High, Medium, and Low priorities.</span>
            </li>
            <li class="flex gap-4">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span>A short readout with recommended next steps into iBOM, Brando policy files, and governed workflows.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. ROLE-INTENT TESTING -->
  <section id="role-intent" class="bg-paper text-ink">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center">Role-Intent Testing</div>
      <h2
        class="mx-auto max-w-5xl text-center text-[clamp(2.4rem,5vw,4.5rem)] font-semibold tracking-tight text-ink"
      >
        We test your brand against the roles and intents your AI will meet in the real world.
      </h2>
      <p class="mx-auto mt-8 max-w-[82ch] text-center text-lg leading-relaxed text-ink/70 md:text-xl">
        Your brand does not fail in theory. It fails in moments. A customer asks
        for reassurance. A journalist asks for proof. A regulator expects
        precision. A sales team pushes for conversion. An AI agent tries to
        summarise, rewrite, compare, recommend, or respond.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-ink/10 bg-fog p-8">
          <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
            Roles
          </div>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink">
            Who is interacting with your brand?
          </h3>
          <p class="mt-4 text-base leading-relaxed text-steel">
            Customers, employees, journalists, partners, regulators, agency
            teams, sales teams, support agents, and AI agents.
          </p>
        </div>

        <div class="rounded-2xl border border-ink/10 bg-fog p-8">
          <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
            Intents
          </div>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink">
            What are they trying to do?
          </h3>
          <p class="mt-4 text-base leading-relaxed text-steel">
            Compare, complain, buy, escalate, summarise, localise, request
            proof, push conversion, create content, or ask for an exception.
          </p>
        </div>
      </div>

      <p class="mx-auto mt-10 max-w-[72ch] text-center text-lg leading-relaxed text-ink/70">
        You see which rules hold, where toolkits create ambiguity, and where
        stronger controls are needed.
      </p>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#concerns"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#e97d5d]"
        >
          <span>See how iBOM works</span>
          <svg class="h-6 w-6 text-paper" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. HOW IBOM WORKS -->
  <section id="concerns" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center opacity-70">How iBOM Works</div>
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper"
      >
        From brand knowledge to governed AI behaviour
      </h2>
      <p class="mx-auto mt-10 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl">
        Most businesses cannot scale what they cannot codify. We move your
        brand standards, expert judgement, and operating rules into a governed
        intelligence layer. Your knowledge. Your rules. Under your control.
      </p>

      <div class="mt-14 grid gap-4 lg:grid-cols-3">
        <div class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur">
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Brand Knowledge Discovery
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We identify the rules, approvals, exceptions, and judgement your
            teams already use. The system starts with how your business really
            works, not a generic template.
          </p>
        </div>

        <div class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur">
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Specification Design
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We turn brand and business logic into explicit specifications. Your
            AI gets rules it can interpret consistently, test, and follow in
            practice.
          </p>
        </div>

        <div class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur">
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Controlled Activation
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We take approved specifications into controlled workflows, review
            paths, and agent behaviours. Build, test, improve, and deploy under
            expert supervision.
          </p>
        </div>
      </div>

      <div class="mt-16 border-t border-paper/20 pt-16">
        <h3 class="text-center text-3xl font-semibold tracking-tight text-paper md:text-4xl">
          Knowledge building and controlled activation
        </h3>
        <p class="mx-auto mt-6 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl">
          We deliver iBOM<sup>&reg;</sup> in two connected phases. The first defines
          and validates your knowledge and specifications. The second turns them
          into governed workflows, controls, and operating capability.
        </p>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2">
        <div class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur">
          <div class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
            Phase 1
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Brand Knowledge Build
          </div>
          <p class="mt-4 text-paper/80">
            We transform standards, toolkits, approvals, and expert judgement
            into structured knowledge your business owns. No vendor lock-in.
            Just portable, governed intelligence.
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Codify</b> brand and business knowledge into high-fidelity structured records.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Construct</b> policy structures, role-intent scenarios, and machine-readable rules.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Validate</b> where the rules hold, conflict, or need stronger governance.</span>
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur">
          <div class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
            Phase 2
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Governed Workflow Activation
          </div>
          <p class="mt-4 text-paper/80">
            We turn the approved knowledge base into controlled AI workflows,
            with access rules, review paths, escalation triggers, and audit
            visibility.
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Design</b> controlled interactions between people, knowledge, and AI systems.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Deploy</b> governed workflows that stay aligned to the approved specification.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"></span>
              <span><b>Operate</b> with monitoring, review, and controlled change as needs evolve.</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#uses"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper transition-colors hover:bg-[#e97d5d]"
        >
          <span>See the framework</span>
          <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. IBOM FRAMEWORK -->
  <section id="uses" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center">Framework</div>
      <h2 class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink">
        iBOM<sup class="text-[0.45em] align-super">&reg;</sup> Framework
      </h2>
