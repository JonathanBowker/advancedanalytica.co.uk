---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AiceGatewayCluster from "../components/AiceGatewayCluster.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../lib/seo/site";
import { businessFunctions } from "../lib/businessFunctions";
import usesPurposeUnderstandingImg from "../components/uses/assessment.svg?url";
import usesSystemFramingImg from "../components/uses/frame.svg?url";
import usesSpecificationDesignImg from "../components/uses/codification.svg?url";
import usesValidationEvaluationImg from "../components/uses/evaluation.svg?url";
import usesExecutionGenerationImg from "../components/uses/operation.svg?url";

const title = "Intelligent Business Operating Model (IBOM)";
const description =
  "Advanced Analytica helps organisations turn business logic into governed, executable infrastructure for AI systems, starting with brand governance.";
const usesTabs = [
  {
    key: "purpose_understanding",
    label: "1. Discover",
    stage: "Stage 1",
    phase: "Phase 1",
    heading: "DISCOVER",
    subheading: "Understand the problem before you build anything.",
    body: "We map your problem, your operating context, and the knowledge already present across your teams, documents, systems, and workflows. Most AI projects fail because they skip this stage. We don't. This is where we establish what's actually known, where ambiguity lives, and what the system needs to account for before a single specification is written.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesPurposeUnderstandingImg,
  },
  {
    key: "system_framing",
    label: "2. Specify",
    stage: "Stage 2",
    phase: "Phase 1",
    heading: "SPECIFY",
    subheading: "Define what the system must know, do, and never do.",
    body: "We turn your problem, rules, constraints, and expectations into explicit specifications. This is where your business defines the system's responsibilities, its boundaries, its prohibited behaviours, and its success criteria in a form that can actually govern execution. Not a requirements doc. A machine-readable governing contract.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesSystemFramingImg,
  },
  {
    key: "specification_design",
    label: "3. Validate",
    stage: "Stage 3",
    phase: "Phase 1",
    heading: "VALIDATE",
    subheading: "Remove ambiguity before a line of code is written.",
    body: "We review, challenge, and confirm the specifications with the people who'll own the outcome. The Deloitte data is clear: most AI pilots stall because production realities weren't accounted for upfront. This stage exists to close that gap. The approved specification becomes the governing contract for development, not a loose reference point.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesSpecificationDesignImg,
  },
  {
    key: "execution_generation",
    label: "4. Develop",
    stage: "Stage 4",
    phase: "Phase 2",
    heading: "DEVELOP",
    subheading: "Build under expert supervision. Never lose the spec.",
    body: "We build the governed system from the approved specifications under direct expert oversight. Every application, agent, workflow, and control is traceable back to the specification. You can see what was built, why it was built that way, and how it behaves. That traceability is what makes scaling possible.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesExecutionGenerationImg,
  },
  {
    key: "validation_evaluation",
    label: "5. Operate",
    stage: "Stage 5",
    phase: "Phase 2",
    heading: "OPERATE",
    subheading: "Run with governance. Extend without losing control.",
    body: "We operate the deployed system through governed infrastructure with monitoring, behavioural controls, and structured extension as your needs evolve. This is the stage most businesses never reach cleanly. We do. Your system stays trustworthy in live use whilst your capability grows without the drift, shadow AI, or ungoverned exceptions that create risk at scale.",
    href: "#get-in-touch",
    cta: "Get in touch",
    image: usesValidationEvaluationImg,
  },
] as const;
const postFilterChips = [
  "All",
  "Governance",
  "Knowledge",
  "Systems",
  "Operation",
  "MCP",
] as const;
const defaultUsesKey = usesTabs[0].key;
const latestPosts = (
  await getCollection("blog", ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const HOME_POST_INITIAL_COUNT = 3;
const HOME_POST_BATCH_SIZE = 3;
const page = {
  title,
  description,
  url: `${SITE_URL}/`,
  breadcrumbs: [{ name: "Home", url: `${SITE_URL}/` }],
};
---

<BaseLayout title={title} description={description} page={page}>
 <!-- 1. HERO -->
<section
  class="relative overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper min-h-[calc(100vh-5rem)]"
>
  <div
    class="container-wide relative z-10 pt-[9.5rem] pb-[8.5rem] lg:pt-[10.5rem] lg:pb-[9.5rem]"
  >
    <div class="grid gap-12 lg:grid-cols-[1fr_0.45fr] lg:items-center">

      <!-- Left: headline + body + CTAs -->
      <div>
        <h1
          class="font-masthead text-[clamp(2.95rem,5.6vw,5.15rem)] font-semibold tracking-tight text-paper leading-[1.06] max-w-[52rem] md:max-w-[56rem]"
        >
          <span class="block">Stop Trusting AI.</span>
          <span class="block text-[#14B8A6]">Start Governing It.</span>
        </h1>
        <h2
          class="mt-6 max-w-[46rem] text-[clamp(1.3rem,2.3vw,2rem)] font-light leading-snug text-paper/100"
        >
          Ungoverned AI isn't assistance. It's a liability.
        </h2>

        <p
          class="mt-5 max-w-[46rem] text-[clamp(1.16rem,1.85vw,1.42rem)] font-light leading-relaxed text-paper/80 md:text-[1.36rem]"
        >
          Most businesses have AI. Few have governed it. We build the
          knowledge infrastructure and runtime controls your business needs to
          close that gap. We turn policy, expert judgement, and business logic
          into
          <strong class="font-medium text-paper">machine-operable controls</strong>.
          Controls that make your AI
          <strong class="font-medium text-paper">consistent, trustworthy, and scalable.</strong>
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          
            <a href="#get-in-touch"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-6 py-3 text-xs font-semibold leading-none tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
          >
            Get in touch
            <svg
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 10h12"></path>
              <path d="M12 6l4 4-4 4"></path>
            </svg>
          </a>
          
            <a href="#why"
            class="inline-flex items-center justify-center gap-3 rounded-md border border-[#ff8c69] px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-[#ff8c69] transition-colors hover:bg-[#ff8c69] hover:text-paper"
          >
            <span>Keep Reading</span>
            <svg
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: stat block -->
      <div class="rounded-2xl border border-paper/10 bg-paper/5 p-8 backdrop-blur">
        <div class="text-[clamp(3.5rem,8vw,6rem)] font-semibold leading-none tracking-tight text-[#14B8A6]">
          74%
        </div>
        <p class="mt-4 text-lg font-light leading-snug text-paper/80">
          of businesses plan to deploy AI agents within two years.
        </p>
        <div class="mt-6 border-t border-paper/15 pt-6">
          <div class="text-[clamp(3.5rem,8vw,6rem)] font-semibold leading-none tracking-tight text-[#ff8c69]">
            21%
          </div>
          <p class="mt-4 text-lg font-light leading-snug text-paper/80">
            have a mature governance model in place to control them.
          </p>
        </div>
        <p class="mt-6 text-xs text-paper/40 leading-relaxed">
          Source: Deloitte State of AI in the Enterprise, January 2026
        </p>
      </div>

    </div>
  </div>
</section>

  <!-- 2. Diagnosis -->
  <section id="why" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-10 text-center">Why It Matters</div>
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <h2
            class="text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
          >
            Your Best People Know Things Your AI Doesn't
          </h2>
        </div>

        <div class="max-w-prose text-lg leading-relaxed text-steel md:text-xl">
          <p>
            In most businesses, the logic that actually drives decisions lives
            in the heads of your best people. Not in your systems. Not in your
            AI. In documents nobody reads, spreadsheets nobody maintains, and
            institutional knowledge that walks out the door.
          </p>

          <p class="mt-6">
            IBOM<sup>®</sup> changes that. It's a brand-first operating model that
            engineers your rules, expert judgement, and business logic into structured
            specifications your AI can actually follow. We establish your AI communication
            protocol. We give your systems the knowledge to behave consistently, at
            scale, under governance.
            <b>We train your AI to govern your AI.</b>
          </p>
        </div>
      </div>
      <div class="mt-12 flex items-center justify-center">
        <a
          href="#concerns"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#e97d5d] transition-colors"
          aria-label="Explore the next section"
        >
          <span>Keep Reading</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 3. How we work -->

  <section id="concerns" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center opacity-70">The Methodology</div>
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper"
      >
        From Dark Knowledge to Governed Intelligence
      </h2>
      <p
        class="mx-auto mt-10 max-w-[90ch] text-lg leading-relaxed text-paper/80 md:text-xl text-center"
      >
        Most businesses can't scale what they can't codify. We move your
        expertise from the <span class="text-paper font-medium"
          >"Dark Knowledge"</span
        > space into a <span class="text-paper font-medium"
          >Governed Intelligence Layer</span
        >
        in three stages. Your knowledge. Your rules. Under your control.
      </p>

      <div class="mt-14 grid gap-4 lg:grid-cols-3">
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Knowledge Discovery
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We extract the business logic, workflow nuances, and institutional
            knowledge your best people carry. The system we build is architected
            around your actual operational DNA. Not a generic template.
          </p>
        </div>
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Spec Engineering
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We codify your requirements into machine language using a domain
            definition language with dot syntax and snake_case. Your AI agents
            can interpret these specifications consistently and follow them in
            practice.
          </p>
        </div>
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
        >
          <h4 class="text-lg font-semibold tracking-tight text-paper">
            Intelligence Activation
          </h4>
          <p class="mt-3 text-base leading-relaxed text-paper/75">
            We take your specifications into production. Build, test, remediate,
            and deploy under direct expert supervision. At the speed your
            business needs.
          </p>
        </div>
      </div>

      <div class="mt-16 border-t border-paper/20 pt-16">
        <h3
          class="text-center text-3xl font-semibold tracking-tight text-paper md:text-4xl"
        >
          Knowledge Building & Intelligence Activation
        </h3>
        <p
          class="mx-auto mt-6 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl"
        >
          We deliver IBOM<sup>®</sup> in two connected phases. The first defines and
          validates your knowledge and specifications. The second develops and operates
          the system through governed infrastructure. Both follow the same five-stage
          model.
        </p>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2">
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]"
          >
            Phase 1
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Knowledge Base Build
          </div>
          <p class="mt-4 text-paper/80">
            We transform institutional wisdom into structured, machine-readable
            datasets your business owns outright. <b>No vendor lock-in.</b> Just portable,
            governed intelligence.
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Codify</b> specialist knowledge into high-fidelity structured
                records.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Construct</b> governed datasets and policy structures expressed
                in a machine-readable domain language.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Deliver</b> a retrieval-ready knowledge base optimised for secure
                exchange.</span
              >
            </li>
          </ul>
        </div>

        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]"
          >
            Phase 2
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Knowledge Base Gateway
          </div>
          <p class="mt-4 text-paper/80">
            We build the retrieval layer that makes your knowledge a live,
            queryable service. <b
              >Your expertise becomes accessible through the AI Communications
              Engine (AICE).</b
            >
          </p>
          <ul class="mt-6 space-y-4 text-paper/75">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Design</b> retrieval systems for real-time accuracy at an enterprise
                scale.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Deploy</b> the AICE as a governed interface for universal AI tool
                connection.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]"
              ></span>
              <span
                ><b>Activate</b> live workflows with automated oversight and deterministic
                controls.</span
              >
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#engine"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper hover:bg-[#e97d5d] transition-colors"
        >
          <span>The Infrastructure</span>
          <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. The Infrastructure -->
  <section id="engine" class="bg-paper py-20 text-ink">
    <div class="container-wide">
      <div class="eyebrow mb-6 text-center">The Infrastructure</div>

      <div class="mx-auto max-w-5xl">
        <h2
          class="text-[clamp(2.2rem,4vw,3.5rem)] font-semibold tracking-tight leading-[1.1] text-center"
        >
          The AICE: Your Intelligence Control Centre
        </h2>
        <div
          class="mt-6 text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6] text-center"
        >
          What it is
        </div>
        <p
          class="mx-auto mt-3 max-w-4xl text-xl text-steel font-light leading-relaxed text-center"
        >
          If the IBOM<sup>®</sup> is the blueprint for your business, the <b
            >AI Communications Engine (AICE)</b
          > is the engine that drives it. It is a secure, controlled gateway that
          sits between your people, your data, and your AI systems. It acts as a permanent
          translator and governor for every AI interaction, turning business intent
          into controlled communications.
        </p>

        <div
          class="mt-8 text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6] text-center"
        >
          What it does
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Translates Intent into Action
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              AI agents don't guess what your business means. The AICE turns
              every request into precise instructions shaped by your rules, your
              logic, and your constraints. Your AI does what you actually
              intend.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Controls What Agents Can Do
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              Unlike traditional AI that recommends, agents act. They send
              communications, make purchases, modify systems. The AICE defines
              the boundaries. What data can be seen. What actions can be taken.
              What must always stay off limits.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              One Governed Point of Control
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              Your AI connects to documents, databases, and operational systems
              through a single governed interface. No sprawl. No shadow AI
              operating outside your visibility. Everything through one
              controlled layer.
            </p>
          </div>
          <div class="rounded-2xl border border-ink/10 bg-fog p-6">
            <h4 class="text-lg font-semibold text-[#14B8A6]">
              Monitors, Audits, and Enforces
            </h4>
            <p class="mt-3 text-steel leading-relaxed">
              The AICE tracks agent behaviour in real time. It catches policy
              violations before they reach users. It maintains the audit trail
              your governance framework depends on. You can see what your AI is
              doing. And prove it.
            </p>
          </div>
        </div>

        <div
          id="ibom-visual"
          class="relative mt-10 w-full scroll-mt-28"
          aria-label="IBOM Intelligent Business Operating Model visualisation"
        >
          <AiceGatewayCluster />
        </div>

        <div
          class="mt-10 rounded-2xl border border-[#14B8A6]/20 bg-[#14B8A6]/5 p-6"
        >
          <div
            class="text-sm font-semibold tracking-[0.16em] uppercase text-[#14B8A6]"
          >
            The Bottom Line
          </div>
          <p class="mt-3 text-lg leading-relaxed text-ink">
            Without the AICE, you're interacting with a chatbot. With AICE,
            you're operating a governed, brand-first intelligence system — with
            the controls, visibility, and audit trail that enterprise AI
            actually requires.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. IBOM Framework (tabs) -->
  <section id="uses" class="bg-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center">Framework</div>
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
      >
        IBOM<sup class="text-[0.45em] align-super">®</sup> Framework
      </h2>
      <p
        class="mx-auto mt-6 max-w-4xl text-center text-lg font-light leading-relaxed text-steel md:text-xl"
      >
        79% of businesses haven't defined how work gets done around AI. Most are
        layering AI onto existing processes and wondering why it doesn't scale.
        IBOM<sup class="text-[0.45em] align-super">®</sup> is built for the other
        way. A five-stage framework that structures how we discover, specify, validate,
        develop, and operate your governed AI system — from first brief to live deployment.
      </p>

      <div class="mt-10">
        <div
          id="uses-tabs"
          role="tablist"
          aria-label="Advanced Analytica IBOM Uses"
          class="flex w-full flex-wrap items-center justify-between gap-1 rounded-md bg-fog p-2"
        >
          {
            usesTabs.map((t) => (
              <button
                type="button"
                role="tab"
                aria-selected={t.key === defaultUsesKey ? "true" : "false"}
                aria-controls={`uses-panel-${t.key}`}
                id={`uses-tab-${t.key}`}
                data-tab={t.key}
                class="flex-1 rounded-md px-5 py-3 text-base font-medium text-ink/80 transition-colors hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-[#14B8A6]/70 aria-selected:bg-[#14B8A6] aria-selected:text-paper aria-selected:shadow-sm"
              >
                {t.label}
              </button>
            ))
          }
        </div>
      </div>

      <div
        class="mt-14 grid gap-12 lg:gap-24 lg:grid-cols-[420px_1fr] lg:items-start"
      >
        <div
          class="relative overflow-hidden rounded-2xl bg-slate shadow-outline"
        >
          <div class="aspect-square">
            {
              usesTabs.map((t) => (
                <img
                  src={t.image}
                  alt=""
                  aria-hidden="true"
                  data-visual={t.key}
                  hidden={t.key === defaultUsesKey ? undefined : true}
                  class="h-full w-full object-cover"
                  decoding="async"
                  loading="lazy"
                />
              ))
            }
          </div>
        </div>

        <div class="max-w-prose pt-2">
          {
            usesTabs.map((t) => (
              <div
                role="tabpanel"
                id={`uses-panel-${t.key}`}
                aria-labelledby={`uses-tab-${t.key}`}
                data-panel={t.key}
                hidden={t.key === defaultUsesKey ? undefined : true}
              >
                <div class="flex flex-wrap items-center gap-3 text-xs font-semibold tracking-[0.2em] uppercase text-steel">
                  <span>{t.stage}</span>
