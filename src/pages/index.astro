  <script is:inline>
    (() => {
      const button = document.getElementById("home-posts-load-more");
      const grid = document.getElementById("home-posts-grid");
      const filterBar = document.getElementById("home-post-filters");
      if (!(button instanceof HTMLButtonElement) || !grid) return;

      const cards = Array.from(grid.querySelectorAll("[data-home-post]"));
      const filters = filterBar
        ? Array.from(filterBar.querySelectorAll("[data-post-filter]"))
        : [];
      const initialCount = Number(
        button.getAttribute("data-initial-count") || "0",
      );
      const batchSize = Number(button.getAttribute("data-batch-size") || "0");
      if (!Number.isFinite(initialCount) || !Number.isFinite(batchSize)) return;

      let activeFilter = "all";

      const getMatchingCards = () =>
        cards.filter((el) => {
          if (activeFilter === "all") return true;
          const tags = (el.getAttribute("data-post-tags") || "").split("|");
          return tags.includes(activeFilter);
        });

      const getVisibleCount = () =>
        getMatchingCards().reduce(
          (count, el) => (el.classList.contains("hidden") ? count : count + 1),
          0,
        );

      const updateButton = () => {
        const matchingCards = getMatchingCards();
        button.style.display =
          getVisibleCount() >= matchingCards.length ? "none" : "";
      };

      const renderCards = (count) => {
        const matchingCards = getMatchingCards();

        cards.forEach((el) => {
          el.classList.add("hidden");
          el.classList.remove("home-post-card-in");
        });

        matchingCards.slice(0, count).forEach((el, index) => {
          el.classList.remove("hidden");
          window.requestAnimationFrame(() => {
            window.setTimeout(
              () => el.classList.add("home-post-card-in"),
              index * 55,
            );
          });
        });

        updateButton();
      };

      button.addEventListener("click", () => {
        const matchingCards = getMatchingCards();
        const visible = getVisibleCount();
        const next = Math.min(matchingCards.length, visible + batchSize);

        for (let i = visible; i < next; i++) {
          const el = matchingCards[i];
          if (!el) continue;
          el.classList.remove("hidden");
          window.requestAnimationFrame(() => {
            window.setTimeout(
              () => el.classList.add("home-post-card-in"),
              (i - visible) * 55,
            );
          });
        }

        updateButton();
      });

      filters.forEach((filter) => {
        filter.addEventListener("click", () => {
          activeFilter = filter.getAttribute("data-post-filter") || "all";
          filters.forEach((el) =>
            el.setAttribute("aria-pressed", el === filter ? "true" : "false"),
          );
          renderCards(initialCount);
        });
      });

      renderCards(initialCount);
    })();

    (() => {
      const scrollButtons = Array.from(
        document.querySelectorAll("[data-scroll-target]"),
      );
      if (!scrollButtons.length) return;

      scrollButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const targetId = button.getAttribute("data-scroll-target");
          if (!targetId) return;
          const target = document.getElementById(targetId);
          target?.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", `#${targetId}`);
        });
      });
    })();
  </script>
