  </section>

  <script is:inline>
    (() => {
      const form = document.querySelector("[data-assessment-flow]");
      if (!(form instanceof HTMLFormElement)) return;

      const panels = Array.from(form.querySelectorAll("[data-step-panel]"));
      const dots = Array.from(form.querySelectorAll("[data-progress-dot]"));
      const progressBar = form.querySelector("[data-progress-bar]");
      const stepTitle = form.querySelector("[data-step-title]");
      const stepSummary = form.querySelector("[data-step-summary]");
      const viewport = form.querySelector("[data-step-viewport]");
      const track = form.querySelector("[data-step-track]");
      const materialsCount = form.querySelector("[data-materials-count]");
      const riskExposuresCount = form.querySelector("[data-risk-exposures-count]");
      const voiceToggle = form.querySelector("[data-voice-input-toggle]");
      const voiceStatus = form.querySelector("[data-voice-input-status]");
      const voiceLabel = form.querySelector("[data-voice-label]");
      const voiceIconIdle = form.querySelector('[data-voice-icon="idle"]');
      const voiceIconActive = form.querySelector('[data-voice-icon="active"]');
      const messageField = form.querySelector("#assessment-message");
      const otherDetailPanels = Array.from(
        form.querySelectorAll("[data-other-details]")
      );
      const requiredCheckboxGroups = ["materials", "risk_exposures"];
      const nextButton = form.querySelector("[data-step-next]");
      const backButton = form.querySelector("[data-step-back]");
      const submitButton = form.querySelector("[data-step-submit]");
      if (!(nextButton instanceof HTMLButtonElement)) return;
      if (!(backButton instanceof HTMLButtonElement)) return;
      if (!(submitButton instanceof HTMLButtonElement)) return;
      if (!(viewport instanceof HTMLElement)) return;
      if (!(track instanceof HTMLElement)) return;
      if (!panels.length) return;

      const SpeechRecognitionCtor =
        window.SpeechRecognition || window.webkitSpeechRecognition || null;
      const supportsVoiceInput =
        typeof SpeechRecognitionCtor === "function" &&
        voiceToggle instanceof HTMLButtonElement &&
        messageField instanceof HTMLTextAreaElement;

      let recognition = null;
      let listening = false;

      let current = 0;

      const stepTitles = [
        "Tell us about your context",
        "Tell us about the current documents",
        "Show us the integrity exposure points",
        "Tell us your biggest risk and next step",
      ];
      const stepSummaries = [
        "Start with who you are, what you are assessing, and the decision you need to support.",
        "Show us the documents and disclosures already available for review.",
        "Show us where gross business integrity risk may already be active.",
        "Finish with the biggest risk and the next step you want us to shape.",
      ];
      const freeEmailDomains = new Set([
        "aol.com",
        "fastmail.com",
        "gmail.com",
        "googlemail.com",
        "gmx.com",
        "gmx.co.uk",
        "hey.com",
        "hotmail.co.uk",
        "hotmail.com",
        "icloud.com",
        "live.co.uk",
        "live.com",
        "mac.com",
        "mail.com",
        "me.com",
        "msn.com",
        "outlook.com",
        "pm.me",
        "proton.me",
        "protonmail.com",
        "qq.com",
        "tutanota.com",
        "yahoo.co.uk",
        "yahoo.com",
        "yandex.com",
        "yandex.ru",
        "zoho.com",
        "163.com",
        "126.com",
      ]);

      const updateSelectionCount = (fieldName, target, emptyCopy, singularLabel, pluralLabel) => {
        if (!(target instanceof HTMLElement)) return;
        const count = form.querySelectorAll(`input[name="${fieldName}"]:checked`).length;
        target.textContent =
          count > 0
            ? `${count} ${count === 1 ? singularLabel : pluralLabel}`
            : emptyCopy;
      };

      const updateMeta = () => {
        if (stepTitle instanceof HTMLElement) {
          stepTitle.textContent =
            stepTitles[current] || `Step ${current + 1} of ${panels.length}`;
        }

        if (stepSummary instanceof HTMLElement) {
          stepSummary.textContent = stepSummaries[current] || "";
        }

        updateSelectionCount(
          "materials",
          materialsCount,
          "Select the material already available for review.",
          "document type selected",
          "document types selected"
        );
        updateSelectionCount(
          "risk_exposures",
          riskExposuresCount,
          "Choose the areas where gross risk may already be active.",
          "risk area selected",
          "risk areas selected"
        );
      };

      const updateViewportHeight = () => {
        const activePanel = panels[current];
        if (!(activePanel instanceof HTMLElement)) return;
        viewport.style.height = `${activePanel.offsetHeight}px`;
      };

      const setVoiceStatus = (text, isError = false) => {
        if (!(voiceStatus instanceof HTMLElement)) return;
        voiceStatus.textContent = text;
        voiceStatus.classList.toggle("text-[#ff8c69]", isError);
        voiceStatus.classList.toggle("text-steel", !isError);
      };

      const cleanDictatedText = (text) => {
        const normalized = text
          .replace(/\s+/g, " ")
          .replace(/\s+([,.!?;:])/g, "$1")
          .trim();

        if (!normalized) return "";

        const withSentenceBreaks = normalized
          .replace(/\b(and|but|so|because|then|also)\b/gi, " $1 ")
          .replace(/\s+/g, " ")
          .trim();

        const sentences = withSentenceBreaks
          .split(/(?<=[.!?])\s+/)
          .map((sentence) => sentence.trim())
          .filter(Boolean)
          .map((sentence) => {
            const capped = sentence.charAt(0).toUpperCase() + sentence.slice(1);
            return /[.!?]$/.test(capped) ? capped : `${capped}.`;
          });

        return sentences.join(" ");
      };

      const updateVoiceToggle = () => {
        if (!(voiceToggle instanceof HTMLButtonElement)) return;
        voiceToggle.setAttribute("aria-pressed", String(listening));
        if (voiceLabel instanceof HTMLElement) {
          voiceLabel.textContent = listening ? "Stop dictating" : "Use voice";
        }
        if (voiceIconIdle instanceof SVGElement) {
          voiceIconIdle.classList.toggle("opacity-0", listening);
        }
        if (voiceIconActive instanceof HTMLElement) {
          voiceIconActive.classList.toggle("opacity-0", !listening);
          voiceIconActive.classList.toggle("animate-pulse", listening);
          voiceIconActive.classList.toggle("scale-110", listening);
          voiceIconActive.classList.toggle("bg-[#ff4d4d]/60", listening);
        }
        voiceToggle.classList.toggle("bg-[#111826]", listening);
        voiceToggle.classList.toggle("border-[#ff4d4d]/80", listening);
      };

      if (supportsVoiceInput) {
        recognition = new SpeechRecognitionCtor();
        recognition.continuous = true;
        recognition.interimResults = true;
        recognition.lang = "en-GB";

        recognition.onstart = () => {
          listening = true;
          updateVoiceToggle();
          setVoiceStatus("Listening. Speak naturally and we’ll add it to the field.");
        };

        recognition.onresult = (event) => {
          if (!(messageField instanceof HTMLTextAreaElement)) return;

          let transcript = "";
          for (let i = event.resultIndex; i < event.results.length; i += 1) {
            const result = event.results[i];
            if (!result.isFinal) continue;
            transcript += result[0].transcript;
          }

          transcript = transcript.trim();
          if (!transcript) return;

          transcript = cleanDictatedText(transcript);
          if (!transcript) return;

          const existing = messageField.value.trim();
          messageField.value = existing ? `${existing} ${transcript}` : transcript;
          messageField.dispatchEvent(new Event("input", { bubbles: true }));
        };

        recognition.onerror = (event) => {
          listening = false;
          updateVoiceToggle();
          setVoiceStatus(
            event.error === "not-allowed"
              ? "Microphone access was blocked."
              : "Voice input stopped.",
            true
          );
        };

        recognition.onend = () => {
          listening = false;
          updateVoiceToggle();
          if (voiceStatus instanceof HTMLElement && !voiceStatus.textContent?.includes("blocked")) {
            setVoiceStatus("Voice input stopped.");
          }
        };

        if (voiceToggle instanceof HTMLButtonElement) {
          voiceToggle.addEventListener("click", () => {
            if (!recognition) return;
            if (listening) {
              recognition.stop();
              return;
            }
            recognition.start();
          });
          updateVoiceToggle();
        }
      } else if (voiceToggle instanceof HTMLButtonElement) {
        voiceToggle.disabled = true;
        voiceToggle.classList.add("opacity-50", "cursor-not-allowed");
        setVoiceStatus("Voice input is not supported in this browser.");
      }

      const validateBusinessEmailField = (emailField) => {
        if (!(emailField instanceof HTMLInputElement)) return true;

        const email = emailField.value.trim().toLowerCase();
        if (!email) {
          emailField.setCustomValidity("");
          return true;
        }

        const domain = email.split("@").pop()?.toLowerCase() || "";
        if (!domain || freeEmailDomains.has(domain)) {
          emailField.setCustomValidity("Please use a business email address.");
          return false;
        }

        emailField.setCustomValidity("");
        return true;
      };

      const syncRequiredCheckboxGroup = (panel, groupName) => {
        if (!(panel instanceof HTMLElement)) return true;

        const fields = Array.from(
          panel.querySelectorAll(`input[type="checkbox"][name="${CSS.escape(groupName)}"]`)
        );
        if (!fields.length) return true;

        const primaryField = fields[0];
        const isValid = fields.some((field) => field.checked);
        primaryField.setCustomValidity(
          isValid ? "" : "Select at least one option."
        );
        return isValid;
      };

      const syncRequiredCheckboxGroups = (panel) => {
        requiredCheckboxGroups.forEach((groupName) => {
          syncRequiredCheckboxGroup(panel, groupName);
        });
      };

      const syncOtherDetails = () => {
        otherDetailPanels.forEach((panel) => {
          if (!(panel instanceof HTMLElement)) return;

          const groupName = panel.dataset.otherDetails;
          if (!groupName) return;

          const otherInput = form.querySelector(
            `input[name="${CSS.escape(groupName)}"][value="Other"]`
          );
          const detailField = panel.querySelector("textarea");
          const isChecked =
            otherInput instanceof HTMLInputElement && otherInput.checked;

          panel.classList.toggle("hidden", !isChecked);

          if (detailField instanceof HTMLTextAreaElement) {
            detailField.disabled = !isChecked;
            detailField.required = isChecked;
            if (!isChecked) {
              detailField.value = "";
            }
          }
        });

        requestAnimationFrame(updateViewportHeight);
      };

      const validateCurrentStep = () => {
        const panel = panels[current];
        if (!(panel instanceof HTMLElement)) return true;

        const emailField = panel.querySelector('[name="email"]');
        if (!validateBusinessEmailField(emailField)) {
          if (emailField instanceof HTMLInputElement) {
            emailField.reportValidity();
          }
          return false;
        }

        syncRequiredCheckboxGroups(panel);

        const fields = Array.from(
          panel.querySelectorAll("input, textarea, select")
        ).filter((field) => field instanceof HTMLElement && !field.hasAttribute("disabled"));

        const radioNames = new Set();

        for (const field of fields) {
          if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement)) {
            continue;
          }

          if (field instanceof HTMLInputElement && field.type === "radio") {
            if (!field.required || radioNames.has(field.name)) continue;
            radioNames.add(field.name);
            const checked = panel.querySelector(`input[name="${CSS.escape(field.name)}"]:checked`);
            if (!checked) {
              field.reportValidity();
              return false;
            }
            continue;
          }

          if (!field.checkValidity()) {
            field.reportValidity();
            return false;
          }
        }

        return true;
      };

      const showStep = (nextIndex) => {
        if (nextIndex < 0 || nextIndex >= panels.length || nextIndex === current) return;

        current = nextIndex;

        track.style.transform = `translate3d(-${current * 100}%, 0, 0)`;

      panels.forEach((panel, index) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.style.minWidth = "100%";
        panel.classList.toggle("is-active", index === current);
        panel.setAttribute("aria-hidden", index === current ? "false" : "true");
      });

        dots.forEach((dot, index) => {
          dot.classList.toggle("is-current", index === current);
          dot.classList.toggle("is-complete", index < current);
          if (dot instanceof HTMLButtonElement) {
            dot.setAttribute("aria-current", index === current ? "step" : "false");
          }
        });

        if (progressBar instanceof HTMLElement) {
          progressBar.style.transform = `scaleX(${(current + 1) / panels.length})`;
        }

        updateMeta();

        backButton.disabled = current === 0;
        nextButton.hidden = current === panels.length - 1;
        submitButton.hidden = current !== panels.length - 1;

        requestAnimationFrame(updateViewportHeight);

        const activePanel = panels[current];
        const focusTarget =
          activePanel instanceof HTMLElement
            ? activePanel.querySelector("input, textarea, select, button")
            : null;
        if (focusTarget instanceof HTMLElement) {
          focusTarget.focus({ preventScroll: true });
        }

        form.scrollIntoView({ block: "start", behavior: "smooth" });
      };

      nextButton.addEventListener("click", () => {
        if (!validateCurrentStep()) return;
        showStep(current + 1);
      });

      backButton.addEventListener("click", () => {
        showStep(current - 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          if (index > current && !validateCurrentStep()) return;
          showStep(index);
        });
      });

      form.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        if (target.name === "materials" || target.name === "risk_exposures") {
          const panel = target.closest("[data-step-panel]");
          if (panel instanceof HTMLElement) {
            syncRequiredCheckboxGroups(panel);
          }
          updateMeta();
        }
        if (
          target.name === "materials" ||
          target.name === "risk_exposures" ||
          target.name === "biggest_concern"
        ) {
          syncOtherDetails();
        }
      });

      form.addEventListener("input", (event) => {
        const target = event.target;
        if (target instanceof HTMLInputElement && target.name === "email") {
          validateBusinessEmailField(target);
        }

        if (target instanceof HTMLTextAreaElement) {
          requestAnimationFrame(updateViewportHeight);
        }
      });

      updateMeta();
      syncOtherDetails();
      panels.forEach((panel) => {
        syncRequiredCheckboxGroups(panel);
      });
      panels.forEach((panel, index) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.setAttribute("aria-hidden", index === current ? "false" : "true");
      });
      dots.forEach((dot, index) => {
        if (dot instanceof HTMLButtonElement) {
          dot.setAttribute("aria-current", index === current ? "step" : "false");
        }
      });
      requestAnimationFrame(updateViewportHeight);
      window.addEventListener("resize", updateViewportHeight);
    })();
  </script>
</BaseLayout>
