---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_URL } from "../lib/seo/site";

const title = "Contextual Risk Assessment";
const description =
  "Request a deep-dive contextual business integrity risk assessment for impact investments, covering inherent risk, integrity due diligence, control gaps, and action planning.";
const leadEndpoint =
  "https://advancedanalytica-co-uk-omj3v.ondigitalocean.app/api/leads/contact";

const page = {
  title,
  description,
  url: `${SITE_URL}/contextual-risk-assessment`,
  breadcrumbs: [
    { name: "Home", url: `${SITE_URL}/` },
    { name: title, url: `${SITE_URL}/contextual-risk-assessment` },
  ],
};

const labelClass =
  "text-sm font-semibold tracking-[0.08em] uppercase text-ink";
const fieldClass =
  "w-full rounded-xl border border-fog bg-white px-4 py-3 text-base text-ink outline-none transition-colors placeholder:text-steel/55 focus:border-[#14B8A6] focus:ring-2 focus:ring-[#14B8A6]/20";
const optionCardClass =
  "flex items-start gap-3 rounded-2xl border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel transition-colors hover:border-[#14B8A6]/40";
const ghostButtonClass =
  "inline-flex items-center justify-center rounded-md border border-fog bg-white px-5 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-ink transition-colors hover:border-ink/30 hover:bg-surface";
const primaryButtonClass =
  "inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-7 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]";

const assessmentAreas = [
  {
    title: "Inherent Risk",
    body: "We identify the gross risk that exists before controls are considered. That includes geography, sector, ownership, licensing, sanctions exposure, political links, public-sector interactions, cash intensity, supply chain complexity, and known issues around fraud, bribery, conflicts, or misconduct."
  },
  {
    title: "Integrity Due Diligence",
    body: "We review the background, track record, reputation, and conduct risks of the investee and key principals. This includes registration, licensing, ownership, watchlists, litigation, public records, media signals, references, and context-specific red flags that require explanation."
  },
  {
    title: "Controls Gap",
    body: "We compare existing business integrity controls against the risk profile and relevant good practice. We look at policies, leadership, accountability, resources, internal controls, monitoring, third-party management, communication, training, reporting, investigation, and remediation."
  },
  {
    title: "Net Risk",
    body: "We separate manageable risks from issues that may require deeper diligence, contractual safeguards, ownership changes, stronger monitoring, or a no-go decision. The output steers a practical action plan linked to risk criticality, responsible owners, timing, and decision implications."
  },
];

const assessmentOutputs = [
  "A written contextual business integrity risk report for the investment or portfolio question",
  "An inherent risk register showing gross risks before mitigation or controls",
  "A gap analysis between existing controls and good-practice business integrity risk management",
  "A prioritised view of Critical, High, Medium, and Low risk findings",
  "A net risk view showing what remains after current controls and proposed mitigations",
  "A practical action-plan steer for diligence, contracting, monitoring, and investment committee decisions",
];

const offerLevels = [
  {
    title: "Risk Triage",
    body: "A lighter review for teams that need to understand the shape of business integrity risk before scoping deeper diligence.",
  },
  {
    title: "Contextual Risk Assessment",
    body: "The deep-dive assessment for impact investors evaluating business integrity risk in an opportunity, portfolio company, or investment thesis.",
  },
  {
    title: "Monitoring and Governance Design",
    body: "The follow-on path for teams ready to turn risk findings into controls, monitoring indicators, contractual safeguards, and decision workflows.",
  },
];

const processSteps = [
  {
    title: "Screen",
    body: "Start with the investment context, sector, geography, ownership, public-sector exposure, commercial pressure, and known red flags. This sets the inherent risk baseline before controls are considered.",
  },
  {
    title: "Request",
    body: "Identify the documents needed to verify disclosures and understand the integrity controls already in place. The request list is shaped around the risks most likely to affect the investment decision.",
  },
  {
    title: "Diligence",
    body: "Review registration, ownership, licences, watchlists, litigation, reputation signals, principal-level concerns, and contextual red flags that need explanation before proceeding.",
  },
  {
    title: "Assess",
    body: "Score gross risk, test mitigations, identify control gaps, and separate managed risks from unresolved exposures. This creates the gap analysis between current controls and good-practice risk management.",
  },
  {
    title: "Act",
    body: "Turn findings into a report, inherent risk register, net-risk view, and action-plan steer for decision-makers. Actions can inform diligence, contracting, safeguards, or investment committee conditions.",
  },
  {
    title: "Monitor",
    body: "Define what should be tracked after the decision, including ownership of actions, timing, evidence requirements, review points, and indicators that residual risk is increasing or reducing.",
  },
];

---

<BaseLayout
  title={title}
  description={description}
  page={page}
  headerContactHref="/company/contact"
  hideFooterContactCta={true}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/50" aria-hidden="true"></div>
    <div class="absolute -left-24 top-16 h-80 w-80 rounded-full bg-[#14B8A6]/12 blur-3xl" aria-hidden="true"></div>
    <div class="absolute right-0 top-10 h-80 w-80 rounded-full bg-[#ff8c69]/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-24">
      <div class="grid gap-12 lg:grid-cols-[7fr_5fr] lg:items-stretch">
        <div>
          <div class="eyebrow text-[#14B8A6]">Impact investment due diligence</div>
          <h1 class="mt-4 text-[clamp(2.4rem,4.8vw,4rem)] font-semibold leading-[1.05] tracking-tight text-paper">
            Contextual business integrity risk analysis for impact investments
          </h1>
          <p class="mt-7 max-w-[72ch] text-lg leading-relaxed text-paper/80 md:text-xl">
            Business integrity risk is not just a compliance checklist. It sits in the
            context around the investee: ownership, public-sector exposure, licensing,
            third parties, incentives, local enforcement, sector pressure, and the way
            controls actually operate. This assessment tests those risks before capital
            is committed.
          </p>
          <p class="mt-5 max-w-[72ch] text-base leading-relaxed text-paper/70 md:text-lg">
            Start with a focused diagnostic. Leave with a report, an inherent risk register, a net-risk view, and a clear steer for gap analysis.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#assessment-form"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-[#14B8A6] px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
            >
              Request assessment
            </a>
            <a
              href="#role-intent-testing"
              class="inline-flex items-center justify-center gap-3 rounded-md border border-[#ff8c69] px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-[#ff8c69] transition-colors hover:bg-[#ff8c69] hover:text-paper"
            >
              What we test
            </a>
          </div>
        </div>

        <div class="flex h-full flex-col rounded-[1.75rem] border border-paper/15 bg-paper/8 p-7 shadow-outline backdrop-blur md:p-8">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full border border-[#ff8c69]/70 text-[#ff8c69]">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 3l2.2 5.4L20 11l-5.8 2.6L12 19l-2.2-5.4L4 11l5.8-2.6L12 3z" />
              </svg>
            </div>
            <div>
              <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ff8c69]">
                You get
              </div>
              <div class="mt-1 text-xs text-paper/55">
                A decision-ready view of business integrity risk.
              </div>
            </div>
          </div>

          <div class="mt-5 border-t border-paper/15 pt-4">
            <ul class="grid gap-0 text-sm leading-relaxed text-paper/80 md:text-sm">
              {assessmentOutputs.map((item) => (
                <li class="flex gap-3 border-b border-paper/10 py-3 last:border-b-0 last:pb-0">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#14B8A6]" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="role-intent-testing" class="bg-paper text-ink">
  <div class="container-wide py-20">
    <div class="eyebrow mb-6 text-center text-[#14B8A6]">Integrity Risk Testing</div>

    <h2 class="text-center text-[clamp(2.4rem,5vw,4.5rem)] font-semibold tracking-tight text-ink">
    We test the investee against the integrity risks it has to manage.   </h2>

    <p class="mx-auto mt-8 max-w-[82ch] text-center text-lg leading-relaxed text-ink/70 md:text-xl">
      Business integrity risk rarely appears as one isolated issue. It shows up in the gap between what is disclosed and what can be verified, the policy and the practice, the control and the workaround, the public-sector interaction and the incentive behind it.
    </p>

    <p class="mx-auto mt-6 max-w-[82ch] text-center text-lg leading-relaxed text-ink/70 md:text-xl">
      We use the Business Integrity Tool logic to move from gross risk to mitigation and net risk, then identify where deeper diligence, stronger safeguards, or an action plan are needed.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <div class="h-full rounded-2xl border border-ink/10 bg-fog p-8">
        <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
          Gross Risk
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink">
          What risks exist before controls?
        </h3>
        <p class="mt-4 text-base leading-relaxed text-steel">
          Jurisdiction, sector, ownership, licensing, sanctions, political exposure, public tenders, cash handling, supply chains, and historic allegations.
        </p>
      </div>

      <div class="h-full rounded-2xl border border-ink/10 bg-fog p-8">
        <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
          Mitigation
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink">
          What controls reduce the risk?
        </h3>
        <p class="mt-4 text-base leading-relaxed text-steel">
          Policies, leadership, resources, internal controls, monitoring, third-party management, reporting channels, investigations, training, and remediation.
        </p>
      </div>
    </div>

    <p class="mx-auto mt-10 max-w-[72ch] text-center text-lg leading-relaxed text-ink/70">
     You see which risks are inherent, which controls are credible, and where net risk could affect the investment decision. </p>
  </div>
</section>

  <section id="what-we-assess" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center text-[#14B8A6]">What We Assess</div>
      <h2 class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper">
        Four criteria that reveal business integrity risk
      </h2>
      <p class="mx-auto mt-10 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl">
        We do not treat business integrity due diligence as a generic checklist. We assess
        gross risk, available evidence, control maturity, and net risk in the context of the investment.
      </p>

      <div class="mt-14 grid gap-4 lg:grid-cols-2">
        {assessmentAreas.map((item, index) => (
          <article class="group rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-[#14B8A6]/40 hover:bg-ink/40">
            <div class="text-lg font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
              0{index + 1}
            </div>
            <h3 class="mt-4 text-2xl font-semibold tracking-tight text-paper">{item.title}</h3>
            <p class="mt-4 text-base leading-relaxed text-paper/75">{item.body}</p>
          </article>
        ))}
      </div>

      
    </div>
  </section>

  <section id="assessment-process" class="bg-paper text-ink">
    <div class="container-wide py-20">
      <div class="eyebrow mb-6 text-center text-[#14B8A6]">Assessment Flow</div>
      <h2 class="mx-auto max-w-[14ch] text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink">
        From context to action plan
      </h2>
      <p class="mx-auto mt-8 max-w-[76ch] text-center text-lg leading-relaxed text-ink/70 md:text-xl">
        The assessment follows the Business Integrity Tool logic: screen the risk,
        verify the evidence, test the controls, then convert findings into a practical
        action plan for diligence, contracting, monitoring, or investment committee decisions.
      </p>

      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {processSteps.map((item, index) => (
          <article class="rounded-2xl border border-ink/10 bg-fog p-6 shadow-outline">
            <div class="text-sm font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
              0{index + 1}
            </div>
            <h3 class="mt-4 text-xl font-semibold tracking-tight text-ink">{item.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-steel">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section
    id="assessment-form"
    class="relative overflow-hidden bg-[url('/images/get-in-touch/bgimage.webp')] bg-cover bg-center"
  >
    <div class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/45 to-black/60" aria-hidden="true"></div>
    <style is:inline>
      .assessment-flow {
        position: relative;
      }

      .assessment-viewport {
        position: relative;
        overflow: hidden;
        transition: height 520ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .assessment-track {
        display: flex;
        align-items: flex-start;
        transform: translate3d(0, 0, 0);
        transition: transform 680ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .assessment-step {
        flex: 0 0 100%;
        min-width: 0;
        opacity: 0.68;
        transform: scale(0.992);
        transition: opacity 480ms ease, transform 480ms ease;
      }

      .assessment-step.is-active {
        opacity: 1;
        transform: scale(1);
      }

      .assessment-step:not(.is-active) {
        pointer-events: none;
        filter: saturate(0.95);
      }

      .assessment-meta-card {
        transition: transform 240ms ease, border-color 240ms ease, box-shadow 240ms ease;
      }

      .assessment-meta-card:hover {
        transform: translateY(-2px);
        border-color: rgba(20, 184, 166, 0.25);
      }

      .assessment-progress-dot {
        cursor: pointer;
        transition: background-color 220ms ease, color 220ms ease, border-color 220ms ease, transform 220ms ease;
      }

      .assessment-progress-dot:focus-visible {
        outline: 3px solid rgba(255, 140, 105, 0.34);
        outline-offset: 3px;
      }

      .assessment-progress-dot.is-current {
        background: #14B8A6;
        border-color: #14B8A6;
        color: #ffffff;
        transform: scale(1.04);
      }

      .assessment-progress-dot.is-complete {
        background: rgba(20, 184, 166, 0.12);
        border-color: rgba(20, 184, 166, 0.35);
        color: #0b0e14;
      }

      .assessment-progress-bar {
        transform-origin: left center;
        transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .assessment-option {
        cursor: pointer;
        transition: transform 220ms ease, border-color 220ms ease, background-color 220ms ease, box-shadow 220ms ease;
      }

      .assessment-option:hover {
        transform: translateY(-1px);
        box-shadow: 0 16px 28px rgba(8, 15, 25, 0.06);
      }

      .assessment-option:has(input:checked) {
        border-color: rgba(20, 184, 166, 0.45);
        background: rgba(20, 184, 166, 0.05);
        box-shadow: 0 18px 34px rgba(20, 184, 166, 0.08);
      }

      .assessment-option:has(input:focus-visible) {
        outline: 3px solid rgba(20, 184, 166, 0.22);
        outline-offset: 2px;
      }

      .assessment-option input:checked + span {
        color: var(--color-ink);
        font-weight: 600;
      }

      @media (prefers-reduced-motion: reduce) {
        .assessment-step,
        .assessment-track,
        .assessment-viewport,
        .assessment-progress-dot,
        .assessment-progress-bar,
        .assessment-option,
        .assessment-meta-card {
          transition: none !important;
        }
      }
    </style>
    <div class="container-wide relative z-10 py-20">
      <div class="mx-auto grid max-w-[1180px] gap-8">
        <div class="eyebrow text-center text-[#14B8A6]">Assessment request</div>
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-[52rem]">
            <h2 class="text-[clamp(2rem,4vw,3.2rem)] font-semibold tracking-tight text-paper">
              Tell us what you are assessing and where integrity risk may sit
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-paper/80">
              Keep this focused. We need enough context to understand the investment,
              the disclosures already available, and the integrity risk questions that matter most.
            </p>
          </div>

          <div class="grid gap-2 rounded-xl border border-paper/20 bg-white/10 px-5 py-4 text-sm text-paper/90 shadow-outline backdrop-blur">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-[#14B8A6]">
              Takes around 3 minutes
            </span>
            <span class="text-paper/85">No file upload needed at this stage.</span>
          </div>
        </div>

        <div class="overflow-hidden rounded-[1.25rem] border border-paper/15 bg-paper/96 text-ink shadow-outline backdrop-blur">
          <form
            id="assessment-form-main"
            action={leadEndpoint}
            method="POST"
            data-lead-form
            data-form-location="contextual_risk_assessment_page"
            data-lead-endpoint={leadEndpoint}
            data-status-target="assessment-status"
            data-success-message="Thanks. Your business integrity risk assessment request has been sent."
            data-success-copy="We will review your context and come back with the right assessment path."
            class="assessment-flow grid gap-6 p-5 md:p-7 lg:p-8"
            data-assessment-flow
            novalidate
          >
            <input
              type="text"
              name="website"
              class="hidden"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <input type="hidden" name="language" value="en" />
            <input
              type="hidden"
              name="topic"
              value="Contextual Business Integrity Risk Assessment"
            />

            <div class="rounded-2xl border border-fog bg-paper p-5 shadow-outline">
              <div class="min-w-0">
                <div class="relative h-1 rounded-full bg-fog">
                  <div
                    class="assessment-progress-bar absolute inset-y-0 left-0 rounded-full bg-[#14B8A6]"
                    data-progress-bar
                    style="width: 100%; transform: scaleX(0.25);"
                  ></div>
                </div>

                <div class="mt-4 grid grid-cols-4 gap-3 text-center text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-steel">
                  <div class="flex flex-col items-center gap-2">
                    <button
                      type="button"
                      class="assessment-progress-dot is-current flex h-9 w-9 items-center justify-center rounded-full border border-fog bg-white"
                      data-progress-dot="0"
                      aria-label="Go to context step"
                    >
                      1
                    </button>
                    <span>Context</span>
                  </div>
                  <div class="flex flex-col items-center gap-2">
                    <button
                      type="button"
                      class="assessment-progress-dot flex h-9 w-9 items-center justify-center rounded-full border border-fog bg-white"
                      data-progress-dot="1"
                      aria-label="Go to documents step"
                    >
                      2
                    </button>
                    <span>Documents</span>
                  </div>
                  <div class="flex flex-col items-center gap-2">
                    <button
                      type="button"
                      class="assessment-progress-dot flex h-9 w-9 items-center justify-center rounded-full border border-fog bg-white"
                      data-progress-dot="2"
                      aria-label="Go to exposure step"
                    >
                      3
                    </button>
                    <span>Decision</span>
                  </div>
                  <div class="flex flex-col items-center gap-2">
                    <button
                      type="button"
                      class="assessment-progress-dot flex h-9 w-9 items-center justify-center rounded-full border border-fog bg-white"
                      data-progress-dot="3"
                      aria-label="Go to risk step"
                    >
                      4
                    </button>
                    <span>Risk</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="assessment-viewport" data-step-viewport>
            <div class="assessment-track" data-step-track>
            <div data-step-panel="0" class="assessment-step is-active grid gap-6 pr-1">
              <div class="rounded-2xl border border-fog bg-paper p-6 shadow-outline">
                <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
                  Step 1
                </div>
                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
                  Tell us about you and the investment context
                </h3>
                <p class="mt-3 text-base leading-relaxed text-steel">
                  Start with the essentials. We need to understand who you are, the investment or portfolio context, and the decision you need to support before we assess business integrity risk properly.
                </p>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div class="grid gap-2">
                  <label for="assessment-name" class={labelClass}>Name*</label>
                  <input
                    id="assessment-name"
                    name="name"
                    type="text"
                    autocomplete="name"
                    required
                    placeholder="Your name"
                    class={fieldClass}
                  />
                </div>
                <div class="grid gap-2">
                  <label for="assessment-email" class={labelClass}>Work email*</label>
                  <input
                    id="assessment-email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    inputmode="email"
                    required
                    placeholder="you@company.com"
                    class={fieldClass}
                  />
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div class="grid gap-2">
                  <label for="assessment-company" class={labelClass}>Company*</label>
                  <input
                    id="assessment-company"
                    name="company"
                    type="text"
                    autocomplete="organization"
                    required
                    placeholder="Company name"
                    class={fieldClass}
                  />
                </div>
                <div class="grid gap-2">
                  <label for="assessment-role" class={labelClass}>Role*</label>
                  <input
                    id="assessment-role"
                    name="role"
                    type="text"
                    required
                    placeholder="Your role"
                    class={fieldClass}
                  />
                </div>
              </div>

              <div class="grid gap-2">
                <div class="flex items-center justify-between gap-3">
                  <label for="assessment-message" class={labelClass}>
                    Tell us what investment, investee, or portfolio question you want assessed?*
                  </label>
                  <button
                    type="button"
                    class="inline-flex items-center gap-2 rounded-full border border-paper/15 bg-ink px-3.5 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-paper shadow-outline transition-colors hover:border-[#14B8A6]/50 hover:bg-[#111826]"
                    data-voice-input-toggle
                    aria-pressed="false"
                    aria-controls="assessment-message"
                  >
                    <span class="relative flex h-4 w-4 items-center justify-center" aria-hidden="true">
                      <svg
                        class="h-4 w-4 data-[recording=true]:opacity-0"
                        data-voice-icon="idle"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.9"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 14a3 3 0 0 0 3-3V7a3 3 0 1 0-6 0v4a3 3 0 0 0 3 3Z" />
