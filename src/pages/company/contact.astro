---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'Contact';
const description = 'Start a governance conversation with Advanced Analytica.';
const leadEndpoint =
  'https://advancedanalytica-co-uk-omj3v.ondigitalocean.app/api/leads/contact';

const page = {
  title,
  description,
  url: `${SITE_URL}/company/contact`,
  schemaType: 'ContactPage',
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Company', url: `${SITE_URL}/company/about` },
    { name: 'Contact', url: `${SITE_URL}/company/contact` }
  ]
};

const labelClass = 'text-sm font-semibold tracking-[0.08em] uppercase text-paper/75';
const fieldClass =
  'w-full rounded-xl border border-paper/15 bg-black/35 px-4 py-3 text-base text-paper outline-none transition-colors placeholder:text-paper/35 focus:border-[#ef27f4] focus:ring-2 focus:ring-[#ef27f4]/25';

const briefingPrompts = [
  'What you want AI or data systems to do better',
  'Where knowledge, policy, approvals, or controls are currently hard to manage',
  'Which teams, tools, workflows, or channels are in scope',
  'Any security, compliance, assurance, or brand governance requirements'
];

const deliveryNotes = [
  {
    title: 'Secure delivery',
    body: 'Your enquiry is submitted through a serverless contact endpoint and routed by AWS SES. Mailbox details and credentials are not exposed in the page.'
  },
  {
    title: 'Confirmation email',
    body: 'The form sends a confirmation email to the address provided, so the sender has a clear record that the enquiry was received.'
  },
  {
    title: 'Human review',
    body: 'We review enquiries directly and use the context provided to decide the most useful next step.'
  }
];
---
<BaseLayout
  title={title}
  description={description}
  page={page}
  hideFooterContactCta={true}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/50" aria-hidden="true"></div>
    <div class="absolute -left-28 top-20 h-80 w-80 rounded-full bg-[#ef27f4]/12 blur-3xl" aria-hidden="true"></div>
    <div class="absolute right-0 top-10 h-80 w-80 rounded-full bg-[#ff8c69]/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-24">
      <div class="grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
        <div>
          <div class="eyebrow text-paper/70">Contact Advanced Analytica</div>
          <h1 class="mt-5 max-w-[12ch] font-masthead text-[clamp(3rem,6vw,5.6rem)] font-normal leading-[1.02] tracking-tight text-paper">
            Ready to put your knowledge to work?
          </h1>
          <p class="mt-7 max-w-[72ch] text-lg leading-relaxed text-paper/80 md:text-xl">
            Tell us what you are trying to improve, what needs governing, and
            where AI or data systems need to work more reliably. We will help
            you turn the problem into a practical next step.
          </p>
          <p class="mt-5 max-w-[72ch] text-base leading-relaxed text-paper/65 md:text-lg">
            You do not need a technical brief. Plain language is enough. We
            work with business leaders, operational teams, technical teams, and
            domain experts to make complex work clear and manageable.
          </p>

          <div class="mt-10 rounded-2xl border border-paper/15 bg-ink/35 p-6 shadow-outline backdrop-blur">
            <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ef27f4]">
              Helpful context
            </div>
            <ul class="mt-5 grid gap-4 text-sm leading-relaxed text-paper/75 md:text-base">
              {briefingPrompts.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#ff8c69]" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="rounded-[1.75rem] border border-paper/15 bg-ink/55 p-6 shadow-outline backdrop-blur md:p-8">
          <div class="mb-7">
            <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ff8c69]">
              Briefing request
            </div>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-paper">
              Send us the outline
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-paper/65">
              The form is routed through our AWS SES-backed serverless endpoint
              and sends a confirmation email to the address you provide.
            </p>
          </div>

        <form
          id="contact-form"
          action={leadEndpoint}
          method="POST"
          data-lead-form
          data-lead-endpoint={leadEndpoint}
          data-status-target="contact-status"
          class="grid gap-5"
          novalidate
        >
          <input
            type="text"
            name="website"
            class="hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="grid gap-2">
            <label for="name" class={labelClass}>Name</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              placeholder="Your name"
              class={fieldClass}
            />
          </div>

          <div class="grid gap-2">
            <label for="email" class={labelClass}>Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
              placeholder="you@example.com"
              class={fieldClass}
            />
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="grid gap-2">
              <label for="company" class={labelClass}>Company</label>
              <input
                id="company"
                name="company"
                type="text"
                autocomplete="organization"
                placeholder="Organisation"
                class={fieldClass}
              />
            </div>
            <div class="grid gap-2">
              <label for="topic" class={labelClass}>Topic</label>
              <select
                id="topic"
                name="topic"
                required
                class={fieldClass}
              >
                <option value="">Select...</option>
                <option>IBOM and governed AI</option>
                <option>Knowledge mapping</option>
                <option>API and MCP infrastructure</option>
                <option>Security and assurance</option>
                <option>Brand, policy, or compliance controls</option>
              </select>
            </div>
          </div>

          <div class="grid gap-2">
            <label for="message" class={labelClass}>Message</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              placeholder="Tell us what you need, what is not working today, or what you would like to build."
              class={`${fieldClass} min-h-40 resize-y`}
            ></textarea>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-4 pt-3">
            <div id="contact-status" class="text-sm text-paper/70" aria-live="polite"></div>
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-md bg-[#ef27f4] px-7 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#d823dd]"
            >
              Send Enquiry
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12" />
                <path d="M12 6l4 4-4 4" />
              </svg>
            </button>
          </div>

          <noscript>
            <p class="text-base text-paper/70">
              JavaScript is disabled. Submitting the form will still send your enquiry through the secure form endpoint.
            </p>
          </noscript>
        </form>
      </div>
    </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-20">
      <div class="grid gap-6 lg:grid-cols-3">
        {deliveryNotes.map((item) => (
          <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
            <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ef27f4]">
              {item.title}
            </div>
            <p class="mt-4 text-base leading-relaxed text-steel">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
