---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'Contact';
const description = 'Start a governance conversation with Advanced Analytica.';
const leadEndpoint =
  'https://advancedanalytica-co-uk-omj3v.ondigitalocean.app/api/leads/contact';

const page = {
  title,
  description,
  url: `${SITE_URL}/company/contact`,
  schemaType: 'ContactPage',
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Company', url: `${SITE_URL}/company/about` },
    { name: 'Contact', url: `${SITE_URL}/company/contact` }
  ]
};

const labelClass = 'text-sm font-semibold tracking-[0.08em] uppercase text-ink';
const fieldClass =
  'w-full rounded-xl border border-fog bg-white px-4 py-3 text-base text-ink outline-none transition-colors placeholder:text-steel/55 focus:border-[#14B8A6] focus:ring-2 focus:ring-[#14B8A6]/20';

const briefingPrompts = [
  'What you want AI or data systems to do better',
  'Where knowledge, policy, approvals, or controls are currently hard to manage',
  'Which teams, tools, workflows, or channels are in scope',
  'Any security, compliance, assurance, or brand governance requirements'
];

const deliveryNotes = [
  {
    title: 'Your message is sent safely',
    body: 'Use the form to share what you need help with. Your enquiry is sent directly to Advanced Analytica so we can review it properly.'
  },
  {
    title: 'You get confirmation',
    body: 'After the form is sent, you will receive a confirmation email at the address you provide, so you know your enquiry has reached us.'
  },
  {
    title: 'We come back with a next step',
    body: 'We read each enquiry and respond with the most useful next step, whether that is a short call, a scoping conversation, or a more detailed briefing.'
  }
];
---
<BaseLayout
  title={title}
  description={description}
  page={page}
  hideFooterContactCta={true}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-black via-[#0b0e14] to-[#171b24] text-paper">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/50" aria-hidden="true"></div>
    <div class="absolute -left-28 top-20 h-80 w-80 rounded-full bg-[#14B8A6]/12 blur-3xl" aria-hidden="true"></div>
    <div class="absolute right-0 top-10 h-80 w-80 rounded-full bg-[#ff8c69]/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-24">
      <div class="grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
        <div>
          <h1 class="text-[clamp(2.2rem,4.6vw,3.75rem)] font-semibold leading-[1.05] tracking-tight text-paper">
            <span class="block">Ready to put your</span>
            <span class="block">knowledge to work?</span>
          </h1>
          <p class="mt-7 max-w-[72ch] text-lg leading-relaxed text-paper/80 md:text-xl">
            Tell us what you are trying to improve, what needs governing, and
            where AI or data systems need to work more reliably. We will help
            you turn the problem into a practical next step.
          </p>

          <div class="mt-8 rounded-2xl border border-paper/15 bg-ink/35 p-6 shadow-outline backdrop-blur md:p-8">
            <h1 class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
              Helpful context
            </h1>
            <ul class="mt-5 grid gap-4 text-sm leading-relaxed text-paper/75 md:text-base">
              {briefingPrompts.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#ff8c69]" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="rounded-[1.75rem] border border-fog bg-surface p-6 text-ink shadow-outline md:p-8">
          <div class="mb-7">
            <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#ff8c69]">
              Briefing request
            </div>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
              Send us the outline
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-steel">
              The form is routed through our AWS SES-backed serverless endpoint
              and sends a confirmation email to the address you provide.
            </p>
          </div>

        <form
          id="contact-form"
          action={leadEndpoint}
          method="POST"
          data-lead-form
          data-lead-endpoint={leadEndpoint}
          data-status-target="contact-status"
          class="grid gap-5"
          novalidate
        >
          <input
            type="text"
            name="website"
            class="hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="grid gap-2">
            <label for="name" class={labelClass}>Name</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              placeholder="Your name"
              class={fieldClass}
            />
          </div>

          <div class="grid gap-2">
            <label for="email" class={labelClass}>Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
              placeholder="you@example.com"
              class={fieldClass}
            />
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="grid gap-2">
              <label for="company" class={labelClass}>Company</label>
              <input
                id="company"
                name="company"
                type="text"
                autocomplete="organization"
                placeholder="Organisation"
                class={fieldClass}
              />
            </div>
            <div class="grid gap-2">
              <label for="topic" class={labelClass}>Topic</label>
              <select
                id="topic"
                name="topic"
                required
                class={fieldClass}
              >
                <option value="">Select...</option>
                <option>IBOM and governed AI</option>
                <option>Knowledge mapping</option>
                <option>API and MCP infrastructure</option>
                <option>Security and assurance</option>
                <option>Brand, policy, or compliance controls</option>
              </select>
            </div>
          </div>

          <div class="grid gap-2">
            <label for="message" class={labelClass}>Message</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              placeholder="Tell us what you need, what is not working today, or what you would like to build."
              class={`${fieldClass} min-h-40 resize-y`}
            ></textarea>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-4 pt-3">
            <div id="contact-status" class="text-sm text-steel" aria-live="polite"></div>
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-md bg-[#14B8A6] px-7 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#0F766E]"
            >
              Send Enquiry
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12" />
                <path d="M12 6l4 4-4 4" />
              </svg>
            </button>
          </div>

          <noscript>
            <p class="text-base text-steel">
              JavaScript is disabled. Submitting the form will still send your enquiry through the secure form endpoint.
            </p>
          </noscript>
        </form>
      </div>
    </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-20">
      <div class="grid gap-6 lg:grid-cols-3">
        {deliveryNotes.map((item) => (
          <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
            <div class="text-xs font-semibold tracking-[0.2em] uppercase text-[#14B8A6]">
              {item.title}
            </div>
            <p class="mt-4 text-base leading-relaxed text-steel">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
