---
import type { EmailOtpType } from '@supabase/supabase-js';
import { createSupabaseServerClient, isSupabaseConfigured } from '../../lib/supabaseServer';

const productionSiteOrigin = 'https://advancedanalytica.co.uk';

function isLocalDevelopmentRequest(request: Request) {
  try {
    const { hostname } = new URL(request.url);
    return hostname === 'localhost' || hostname === '127.0.0.1' || hostname === '::1';
  } catch {
    return false;
  }
}

function getPublicOrigin(request: Request) {
  const requestUrl = new URL(request.url);

  if (isLocalDevelopmentRequest(request)) {
    return requestUrl.origin;
  }

  const forwardedHost = request.headers.get('x-forwarded-host')?.split(',')[0]?.trim();
  const forwardedProto = request.headers.get('x-forwarded-proto')?.split(',')[0]?.trim() || 'https';

  if (forwardedHost && !forwardedHost.endsWith('.ondigitalocean.app')) {
    return `${forwardedProto}://${forwardedHost}`;
  }

  return productionSiteOrigin;
}

if (!isSupabaseConfigured) {
  return Astro.redirect('/login?error=config');
}

const supabase = createSupabaseServerClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const requestUrl = new URL(Astro.request.url);
const authCode = requestUrl.searchParams.get('code');
const tokenHash = requestUrl.searchParams.get('token_hash');
const type = requestUrl.searchParams.get('type') as EmailOtpType | null;
const requestedNextPath = requestUrl.searchParams.get('next');
const nextPath = requestedNextPath?.startsWith('/') ? requestedNextPath : '/portal';

let success = false;
let callbackError = '';

if (authCode) {
  const { error } = await supabase.auth.exchangeCodeForSession(authCode);
  success = !error;
  callbackError = error?.message || '';
} else if (tokenHash && type) {
  const { error } = await supabase.auth.verifyOtp({
    token_hash: tokenHash,
    type,
  });
  success = !error;
  callbackError = error?.message || '';
}

if (success) {
  return Astro.redirect(nextPath);
}

const loginErrorUrl = new URL('/login', getPublicOrigin(Astro.request));
loginErrorUrl.searchParams.set('error', 'callback');
if (callbackError) {
  loginErrorUrl.searchParams.set('error_description', callbackError);
}

return Astro.redirect(loginErrorUrl.toString());
---
