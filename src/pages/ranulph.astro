---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_URL } from "../lib/seo/site";

const title = "Ranulph";
const description =
  "A forward-looking integrity risk tool for growth-stage investors, portfolio teams, and businesses facing real operating-context risk.";
const leadEndpoint =
  "https://advancedanalytica-co-uk-omj3v.ondigitalocean.app/api/leads/contact";

const page = {
  title,
  description,
  url: `${SITE_URL}/ranulph`,
  breadcrumbs: [
    { name: "Home", url: `${SITE_URL}/` },
    { name: title, url: `${SITE_URL}/ranulph` },
  ],
};

const labelClass =
  "text-sm font-semibold tracking-[0.08em] uppercase text-ink";
const fieldClass =
  "w-full rounded-xl border border-fog bg-white px-4 py-3 text-base text-ink outline-none transition-colors placeholder:text-steel/55 focus:border-[#14B8A6] focus:ring-2 focus:ring-[#14B8A6]/20";
const branchA = [
  {
    id: "risk_assessment",
    name: "Where's my real exposure?",
    when: "Entering a new market, weighing an opportunity, or refreshing your assessment.",
    value:
      "Most risk registers describe the world as it was. Ranulph builds a forward-looking picture of where your exposure actually sits, by market, by counterparty, by control. You see the hotspots before they cost you.",
    freebie:
      "Risk Assessment, Document Review, Gap Analysis, and Action Plan template.",
    next: "Get the template",
    cta: "Get my template",
  },
  {
    id: "benchmark_gap",
    name: "Benchmark and Gap Analysis",
    when:
      "You have a framework, policy, or control set and want to know if it holds up against best practice.",
    value:
      "A policy that reads well and a framework that works are different things. Ranulph benchmarks what you have, and how you do it, against what good looks like, then shows you the gaps that matter and the ones that do not.",
    freebie: "Benchmark and Gap Analysis template.",
    next: "Get the template",
    cta: "Get my template",
  },
  {
    id: "implementation_support",
    name: "Implementation Support",
    when:
      "You know the gap and need content, training, or hands to close it.",
    value:
      "Sixty-seven percent of integrity failures come from implementation, not policy. Ranulph turns an action plan into something your people actually do, backed by a 93% implementation rate against an industry norm nearer 25%.",
    freebie: "Making risk relevant whitepaper or a direct scoping call.",
    next: "Discuss the implementation gap",
    cta: "Book the call",
  },
  {
    id: "fraud_controls",
    name: "Fraud Controls Diagnostic",
    when: "You have a nagging worry, a board question, or a near miss.",
    value:
      "A short, structured diagnostic that blends ACCA fraud prevention work, the ACFE Report to the Nations, and Business Fraud Alliance tools into one quick assessment. Answer a handful of questions and see where fraud is most likely to hide in a business like yours.",
    freebie: "Blended fraud self-assessment.",
    next: "Start the diagnostic",
    cta: "Start the diagnostic",
  },
  {
    id: "triage_response",
    name: "Triage and Response",
    when:
      "You have a whistleblower report, an adverse finding, or a problem that has already landed.",
    value:
      "When something has already gone wrong, the first decisions are critical. Ranulph helps you triage what you are facing, decide what needs a human, and respond without making it worse.",
    freebie: "Investigation essentials pack.",
    next: "Get fast response",
    cta: "Send",
    urgent: true,
  },
];

const branchB = [
  {
    id: "pipeline_screen",
    name: "Screen the pipeline",
    when:
      "High deal volume, and you need to know fast which opportunities make sense to pursue.",
    value:
      "Before you spend real diligence money, Ranulph gives you a fast, consistent read on each opportunity, so you put your effort where the risk and the upside actually are.",
    freebie: "Sample one-page screen output.",
    next: "See the sample",
    cta: "Get the sample",
  },
  {
    id: "deal_deep_dive",
    name: "Deal deep-dive",
    when:
      "One target, and you want the gaps and a usable action plan, not a 90-page PDF nobody reads.",
    value:
      "A forward-looking analysis of a potential deal, partner, or counterparty: where the integrity risk sits, what the existing material misses, and a clear action plan you can attach to the deal. Built to inform an IC decision and post-transaction security.",
    freebie: "Risk Assessment and Action Plan template plus redacted deal example.",
    next: "Request the deep-dive",
    cta: "Request assessment",
  },
  {
    id: "portfolio_benchmark",
    name: "Benchmark the portfolio",
    when:
      "Existing holdings, and you want a consistent integrity read across them.",
    value:
      "One company or the whole book, benchmarked the same way, so you can identify potential risks, share best practice, implement across multiple holdings, and prepare for profitable exits.",
    freebie: "Gap Analysis and Benchmark template.",
    next: "Benchmark the portfolio",
    cta: "Request assessment",
  },
  {
    id: "specific_concern",
    name: "Something's not quite right",
    when:
      "A particular worry on a target or holding: fraud, reporting, or a whistleblower signal.",
    value:
      "Sometimes it is one thing keeping you up. Ranulph helps you test the specific concern quickly and quietly, before it becomes a bigger issue.",
    freebie: "Fraud self-assessment or investigation report template.",
    next: "Test the concern",
    cta: "Start the diagnostic",
  },
  {
    id: "harmoniser",
    name: "Reconciling multiple asks",
    when:
      "An investee or co-investor has multiple action plans, policies, or compliance asks that overlap or conflict.",
    value:
      "When three investors have even more different action plans, complying with all of them is a full-time job. Ranulph reconciles overlapping and conflicting obligations into one coherent plan, so you do the work once.",
    freebie: "Harmoniser GPT MVP.",
    next: "Try the Harmoniser",
    cta: "Try the Harmoniser",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  page={page}
  headerContactHref="/company/contact"
  hideFooterContactCta={true}
>
  <style is:inline>
    html {
      scroll-behavior: smooth;
    }

    .ranulph-option {
      width: min(100%, 38rem);
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: transparent;
      color: #ffffff;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease;
    }

    .ranulph-option:hover,
    .ranulph-option:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(255, 255, 255, 0.38);
      background: rgba(255, 255, 255, 0.05);
      outline: none;
    }

    .ranulph-option-light {
      border-color: rgba(5, 5, 5, 0.16);
      color: #050505;
    }

    .ranulph-option-light:hover,
    .ranulph-option-light:focus-visible {
      border-color: rgba(5, 5, 5, 0.38);
      background: rgba(5, 5, 5, 0.04);
    }

    .ranulph-reveal {
      animation: ranulph-rise 360ms ease-out;
    }

    @keyframes ranulph-rise {
      from {
        opacity: 0;
        transform: translateY(18px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      .ranulph-option,
      .ranulph-reveal {
        transition: none;
        animation: none;
      }
    }
  </style>

  <div>
  <section class="border-b border-white/10 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08),transparent_28%),linear-gradient(180deg,#050505_0%,#0b0b0b_52%,#050505_100%)] py-24 text-paper">
    <div class="container-wide text-center">
      <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-white/58">
        Ranulph
      </div>
        <h1 class="mx-auto mt-6 max-w-[64rem] font-masthead text-[clamp(3rem,8vw,6.25rem)] font-semibold leading-[0.97] tracking-tight text-white">
          The risks you'll actually face don't show up in compliance checklists.
        </h1>
        <p class="mx-auto mt-8 max-w-[48rem] text-[clamp(1.05rem,2.2vw,1.55rem)] leading-relaxed text-white/74">
          Ranulph replaces box-ticking assessments with forward-looking risk
          intelligence for growth-stage investors.
        </p>
        <p class="mt-6 text-[clamp(1.2rem,2.8vw,1.9rem)] font-semibold uppercase tracking-[0.22em] text-white">
          Expert judgement. AI-accelerated.
        </p>
    </div>
  </section>

  <section id="start" class="border-b border-[#050505]/10 bg-[#f3f0e8] py-24 text-[#050505]">
    <div class="container-wide flex flex-col items-center text-center">
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[#050505]/58">
          Where to start
        </div>
        <h2 class="mt-6 max-w-[60rem] font-masthead text-[clamp(2.2rem,5vw,4.4rem)] font-semibold leading-[1.02] tracking-tight text-[#050505] md:max-w-[64rem]">
          Whose risk are you trying to understand?
        </h2>

      <div class="mt-12 flex w-full flex-col items-center gap-4">
        <button
          type="button"
          class="ranulph-option ranulph-option-light rounded-[2rem] px-8 py-5 text-center text-xl leading-relaxed"
          data-branch-choice="own"
        >
          My own organisation
        </button>
        <button
          type="button"
          class="ranulph-option ranulph-option-light rounded-[2rem] px-8 py-5 text-center text-xl leading-relaxed"
          data-branch-choice="other"
        >
          Another business
        </button>
      </div>
    </div>
  </section>

  <section id="branch-own" class="hidden border-b border-white/10 bg-[#14B8A6] py-24 text-paper" data-branch-section="own">
    <div class="container-wide">
      <div class="mx-auto max-w-[980px] text-center">
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-white/70">What you need</div>
        <h2 class="mt-6 font-masthead text-[clamp(2.2rem,5vw,4rem)] font-semibold leading-[1.03] tracking-tight text-white">
          Where are you right now?
        </h2>
      </div>
      <div class="mt-12 grid gap-5 lg:grid-cols-2">
        {branchA.map((card) => (
          <article class="rounded-[2rem] border border-white/24 bg-transparent p-6 text-white">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <h3 class="font-masthead text-3xl font-semibold tracking-tight text-white">{card.name}</h3>
                <p class="mt-3 text-sm font-semibold uppercase tracking-[0.14em] text-white/70">
                  {card.when}
                </p>
              </div>
              {card.urgent && (
                <span class="rounded-[2rem] border border-white/60 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white">
                  Urgent
                </span>
              )}
            </div>
            <p class="mt-5 text-base leading-relaxed text-white/82">{card.value}</p>
            <div class="mt-5 rounded-[1.5rem] border border-white/24 bg-white/8 p-4 text-sm leading-relaxed text-white/78">
              <span class="font-semibold text-white">Free asset: </span>{card.freebie}
            </div>
            <button
              type="button"
              class="ranulph-option mt-6 rounded-[2rem] px-8 py-4 text-base font-semibold"
              data-leaf-choice
              data-branch="own"
              data-leaf={card.id}
              data-freebie={card.freebie}
              data-submit-label={card.cta}
            >
              {card.next}
            </button>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="branch-other" class="hidden border-b border-[#050505]/10 bg-[#ff8c69] py-24 text-[#050505]" data-branch-section="other">
    <div class="container-wide">
      <div class="mx-auto max-w-[980px] text-center">
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[#050505]/58">What you need to understand</div>
        <h2 class="mt-6 font-masthead text-[clamp(2.2rem,5vw,4rem)] font-semibold leading-[1.03] tracking-tight text-[#050505]">
          What do you need to understand?
        </h2>
      </div>
      <div class="mt-12 grid gap-5 lg:grid-cols-2">
        {branchB.map((card) => (
          <article class="rounded-[2rem] border border-[#050505]/16 bg-transparent p-6 text-[#050505]">
            <h3 class="font-masthead text-3xl font-semibold tracking-tight text-[#050505]">{card.name}</h3>
            <p class="mt-3 text-sm font-semibold uppercase tracking-[0.14em] text-[#050505]/62">
              {card.when}
            </p>
            <p class="mt-5 text-base leading-relaxed text-[#050505]/78">{card.value}</p>
            <div class="mt-5 rounded-[1.5rem] border border-[#050505]/16 bg-[#050505]/5 p-4 text-sm leading-relaxed text-[#050505]/74">
              <span class="font-semibold text-[#050505]">Free asset: </span>{card.freebie}
            </div>
            <button
              type="button"
              class="ranulph-option ranulph-option-light mt-6 rounded-[2rem] px-8 py-4 text-base font-semibold"
              data-leaf-choice
              data-branch="other"
              data-leaf={card.id}
              data-freebie={card.freebie}
              data-submit-label={card.cta}
            >
              {card.next}
            </button>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="how-it-works" class="border-b border-[#050505]/10 bg-[#f3f0e8] py-24 text-[#050505]">
    <div class="container-wide">
      <div class="mx-auto max-w-[980px] text-center">
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[#050505]/58">How it works</div>
          <h2 class="mt-6 font-masthead text-[clamp(2.2rem,5vw,4rem)] font-semibold leading-[1.03] tracking-tight text-[#050505]">
            Context-first. Expert-led. AI-assisted.
          </h2>
      </div>
        <div class="mt-12 grid gap-4 md:grid-cols-3">
          <div class="rounded-[2rem] border border-[#050505]/16 bg-transparent p-6">
            <div class="font-masthead text-3xl font-semibold tracking-tight text-ink">Step 1</div>
            <p class="mt-4 text-base leading-relaxed text-steel">
              Ranulph starts with the operating context: market, counterparty,
              incentives, controls, and the point where risk becomes real before
              a policy or checklist can see it.
            </p>
          </div>
          <div class="rounded-[2rem] border border-[#050505]/16 bg-transparent p-6">
            <div class="font-masthead text-3xl font-semibold tracking-tight text-ink">Step 2</div>
            <p class="mt-4 text-base leading-relaxed text-steel">
           Human-in-the-loop brings expert judgement into the process, so AI can accelerate integrity analysis without replacing accountability.
            </p>
          </div>
          <div class="rounded-[2rem] border border-[#050505]/16 bg-transparent p-6">
            <div class="font-masthead text-3xl font-semibold tracking-tight text-ink">Step 3</div>
            <p class="mt-4 text-base leading-relaxed text-steel">
              You leave with a next step: a practical asset, a diagnostic, a
              scoping call, or a deeper assessment path linked to what you are
              actually trying to decide.
            </p>
          </div>
        </div>
      </div>
  </section>

  <section id="contact" class="hidden border-b border-white/10 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08),transparent_28%),linear-gradient(180deg,#050505_0%,#0b0b0b_52%,#050505_100%)] py-24 text-paper" data-contact-section>
    <div class="container-wide">
      <div class="mx-auto grid max-w-[1080px] gap-8">
        <div class="max-w-[52rem]">
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-white/58">Next step</div>
          <h2 class="mt-6 font-masthead text-[clamp(2.2rem,5vw,4rem)] font-semibold leading-[1.03] tracking-tight text-white" data-form-heading>
            Tell us where to send it
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-paper/72" data-form-summary>
            We will tag your enquiry with the path you selected and come back
            with the right next step.
          </p>
        </div>

        <form
          id="ranulph-form"
          action={leadEndpoint}
          method="POST"
          data-lead-form
          data-form-location="ranulph_page"
          data-lead-endpoint={leadEndpoint}
          data-status-target="ranulph-status"
          data-success-message="Done. Check your inbox, and we'll come back with the right next step."
          data-success-copy="Your enquiry has been tagged with the path you selected."
          class="grid gap-5 rounded-[2rem] border border-paper/15 bg-paper/96 p-6 text-ink shadow-outline"
          novalidate
        >
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="language" value="en" />
          <input type="hidden" name="topic" value="Ranulph enquiry" />
          <input type="hidden" name="branch" data-hidden-branch />
          <input type="hidden" name="leaf" data-hidden-leaf />
          <input type="hidden" name="freebie_requested" data-hidden-freebie />
          <input type="hidden" name="urgency_flag" data-hidden-urgency value="false" />
          <input type="hidden" name="clickstream_data" data-hidden-clickstream />

          <div class="grid gap-5 md:grid-cols-2">
            <div class="grid gap-2">
              <label for="ranulph-name" class={labelClass}>Name*</label>
              <input id="ranulph-name" name="name" type="text" required autocomplete="name" placeholder="Your name" class={fieldClass} />
            </div>
            <div class="grid gap-2">
              <label for="ranulph-email" class={labelClass}>Email*</label>
              <input id="ranulph-email" name="email" type="email" required autocomplete="email" inputmode="email" placeholder="you@example.com" class={fieldClass} />
            </div>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="grid gap-2">
              <label for="ranulph-organisation" class={labelClass}>Organisation*</label>
              <input id="ranulph-organisation" name="organisation" type="text" required autocomplete="organization" placeholder="Organisation name" class={fieldClass} />
            </div>
            <div class="grid gap-2" data-role-field>
              <label for="ranulph-role" class={labelClass}>Your role</label>
              <select id="ranulph-role" name="role" class={fieldClass}>
                <option value="">Select if relevant</option>
                <option>Deal manager</option>
                <option>Direct investor</option>
                <option>Advisor vetting a target</option>
                <option>Internal integrity, ESG or risk</option>
                <option>Investee or co-investor</option>
              </select>
            </div>
          </div>

          <div class="grid gap-2">
            <div class={labelClass}>Preferred next step*</div>
            <div class="grid gap-3 md:grid-cols-3">
              <label class="flex items-start gap-3 rounded-[2rem] border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel">
                <input type="radio" name="preferred_next_step" value="Book a scoping call" required class="mt-1 h-4 w-4 accent-[#14B8A6]" />
                <span>Book a scoping call</span>
              </label>
              <label class="flex items-start gap-3 rounded-[2rem] border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel">
                <input type="radio" name="preferred_next_step" value="Request a deep-dive assessment" class="mt-1 h-4 w-4 accent-[#14B8A6]" />
                <span>Request a deep-dive assessment</span>
              </label>
              <label class="flex items-start gap-3 rounded-[2rem] border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel">
                <input type="radio" name="preferred_next_step" value="Share documents first" class="mt-1 h-4 w-4 accent-[#14B8A6]" />
                <span>
                  <span class="block font-semibold text-ink">Share documents first</span>
                  <span class="mt-1 block text-xs leading-relaxed text-steel">
                    Secure file-transfer link sent after submission.
                  </span>
                </span>
              </label>
            </div>
          </div>

          <label class="flex items-start gap-3 rounded-2xl border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel">
            <input type="checkbox" name="time_sensitive" value="yes" class="mt-1 h-4 w-4 accent-[#14B8A6]" data-urgency-toggle />
            <span>
              <span class="block font-semibold text-ink">Is this time-sensitive?</span>
              <span>Use this only if something needs a fast human response.</span>
            </span>
          </label>

          <div class="grid gap-2">
            <label for="ranulph-note" class={labelClass}>Anything we should know?</label>
            <textarea id="ranulph-note" name="message" rows="4" placeholder="One optional line of context." class={`${fieldClass} resize-y`}></textarea>
          </div>

          <label class="flex items-start gap-3 rounded-2xl border border-fog bg-white px-4 py-4 text-sm leading-relaxed text-steel">
            <input type="checkbox" name="confidentiality_consent" value="yes" required class="mt-1 h-4 w-4 accent-[#14B8A6]" />
            <span>I understand Ranulph handles this enquiry under confidentiality.</span>
          </label>

          <div class="flex flex-wrap items-center justify-between gap-4">
            <div id="ranulph-status" class="text-sm text-steel" aria-live="polite"></div>
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-[2rem] bg-[#050505] px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-[#222222]"
              data-submit-button
            >
              Send
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="container-wide py-10">
      <div class="grid gap-4 text-sm leading-relaxed text-paper/65 md:grid-cols-3">
        <p>Ranulph is built by Ethics Insight.</p>
        <p>Ethics Insight legal and privacy terms apply to submitted enquiries and shared materials.</p>
        <p>Human review is used where context, urgency, or confidentiality requires it.</p>
      </div>
    </div>
  </section>
  </div>

  <script is:inline>
    (() => {
      const branchButtons = Array.from(document.querySelectorAll("[data-branch-choice]"));
      const branchSections = Array.from(document.querySelectorAll("[data-branch-section]"));
      const leafButtons = Array.from(document.querySelectorAll("[data-leaf-choice]"));
      const contactSection = document.querySelector("[data-contact-section]");
      const formHeading = document.querySelector("[data-form-heading]");
      const formSummary = document.querySelector("[data-form-summary]");
      const hiddenBranch = document.querySelector("[data-hidden-branch]");
      const hiddenLeaf = document.querySelector("[data-hidden-leaf]");
      const hiddenFreebie = document.querySelector("[data-hidden-freebie]");
      const hiddenUrgency = document.querySelector("[data-hidden-urgency]");
      const hiddenClickstream = document.querySelector("[data-hidden-clickstream]");
      const urgencyToggle = document.querySelector("[data-urgency-toggle]");
      const submitButton = document.querySelector("[data-submit-button]");
      const form = document.querySelector("#ranulph-form");

      const sessionKey = "ranulph_clickstream";
      const now = () => new Date().toISOString();
      const createId = () =>
        globalThis.crypto?.randomUUID?.() ||
        `ranulph-${Date.now()}-${Math.random().toString(16).slice(2)}`;

      const initialClickstream = () => ({
        session_id: createId(),
        timestamp_start: now(),
        events: [],
        branch: "",
        leaf: "",
        role: "",
        freebie_requested: "",
        urgency_flag: false,
      });

      const readClickstream = () => {
        try {
          const stored = localStorage.getItem(sessionKey);
          return stored ? JSON.parse(stored) : initialClickstream();
        } catch {
          return initialClickstream();
        }
      };

      let clickstream = readClickstream();

      const syncClickstream = () => {
        if (hiddenClickstream instanceof HTMLInputElement) {
          hiddenClickstream.value = JSON.stringify(clickstream);
        }
        localStorage.setItem(sessionKey, JSON.stringify(clickstream));
      };

      const track = (event, value = "") => {
        clickstream.events.push({ event, value, timestamp: now() });
        syncClickstream();
      };

      const scrollToElement = (element) => {
        if (element instanceof HTMLElement) {
          element.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      };

      const showBranch = (branch) => {
        branchSections.forEach((section) => {
          if (!(section instanceof HTMLElement)) return;
          const isActive = section.dataset.branchSection === branch;
          section.classList.toggle("hidden", !isActive);
        });

        clickstream.branch = branch;
        clickstream.leaf = "";
        clickstream.freebie_requested = "";

        if (hiddenBranch instanceof HTMLInputElement) hiddenBranch.value = branch;
        if (hiddenLeaf instanceof HTMLInputElement) hiddenLeaf.value = "";
        if (hiddenFreebie instanceof HTMLInputElement) hiddenFreebie.value = "";

        if (contactSection instanceof HTMLElement) contactSection.classList.add("hidden");
        track("branch_selected", branch);
        const activeSection = document.querySelector(`[data-branch-section="${branch}"]`);
        scrollToElement(activeSection);
      };

      const showContact = (button) => {
        if (!(button instanceof HTMLElement)) return;

        const branch = button.dataset.branch || "";
        const leaf = button.dataset.leaf || "";
        const freebie = button.dataset.freebie || "";
        const submitLabel = button.dataset.submitLabel || "Send";

        clickstream.branch = branch;
        clickstream.leaf = leaf;
        clickstream.freebie_requested = freebie;

        if (hiddenBranch instanceof HTMLInputElement) hiddenBranch.value = branch;
        if (hiddenLeaf instanceof HTMLInputElement) hiddenLeaf.value = leaf;
        if (hiddenFreebie instanceof HTMLInputElement) hiddenFreebie.value = freebie;
        if (submitButton instanceof HTMLButtonElement) submitButton.textContent = submitLabel;

        const isFreebie = /template|diagnostic|sample|Harmoniser|pack|whitepaper/i.test(freebie);
        if (formHeading instanceof HTMLElement) {
          formHeading.textContent = isFreebie
            ? "Tell us where to send it"
            : "Let's get you to the right place";
        }
        if (formSummary instanceof HTMLElement) {
          formSummary.textContent = freebie
            ? `Selected path: ${freebie}`
            : "We will tag your enquiry with the path you selected and come back with the right next step.";
        }

        if (contactSection instanceof HTMLElement) contactSection.classList.remove("hidden");
        track("leaf_selected", leaf);
        track("freebie_requested", freebie);
        scrollToElement(contactSection);
      };

      branchButtons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          showBranch(button.dataset.branchChoice || "");
        });
      });

      leafButtons.forEach((button) => {
        button.addEventListener("click", () => showContact(button));
      });

      if (urgencyToggle instanceof HTMLInputElement) {
        urgencyToggle.addEventListener("change", () => {
          const value = urgencyToggle.checked;
          clickstream.urgency_flag = value;
          if (hiddenUrgency instanceof HTMLInputElement) {
            hiddenUrgency.value = String(value);
          }
          track("urgency_changed", String(value));
        }, { capture: true });
      }

      if (form instanceof HTMLFormElement) {
        form.addEventListener("submit", () => {
          const role = form.querySelector('[name="role"]');
          if (role instanceof HTMLSelectElement) {
            clickstream.role = role.value;
          }
          track("form_submitted", clickstream.leaf || "");
          syncClickstream();
        });
      }

      syncClickstream();
    })();
  </script>
</BaseLayout>
